---
import Layout from '../layouts/Layout.astro';

const researchThreads = [
  {
    title: 'Structural Bioinformatics',
    text: 'Building toward research workflows that connect protein structure prediction, docking, and careful validation for biomedical questions.',
  },
  {
    title: 'Reproducible Workflows',
    text: 'Interested in pipeline design, quality control, documentation, and reporting practices that make computational biology easier to audit and extend.',
  },
  {
    title: 'Biomedical Data Integration',
    text: 'Long-term interest in connecting genomic, clinical, structural, and healthcare operational data responsibly for precision medicine research.',
  },
];
---

<Layout title="Research - Prithvi Rajan" description="Research interests and direction of Prithvi Rajan.">
  <div class="container">
    <div class="page-header">
      <div class="page-copy">
        <p class="eyebrow">Research Direction</p>
        <h1>Research <span class="accent">.</span></h1>
        <p class="page-sub">
          I am building research practice across structural biology, biomedical data systems, and reproducible computational workflows.
        </p>
      </div>
    </div>

    <section class="research-grid">
      {researchThreads.map(item => (
        <article class="research-card will-animate">
          <h2>{item.title}</h2>
          <p>{item.text}</p>
        </article>
      ))}
    </section>

  </div>
</Layout>

<style>
.page-header {
  padding: 2.4rem 2rem 2rem;
  border-bottom: 1px solid var(--color-border);
  margin-bottom: 2.5rem;
}
.page-copy {
  max-width: 760px;
}
.eyebrow {
  font-family: var(--font-sans);
  font-size: 0.76rem;
  font-weight: 600;
  letter-spacing: 0.08em;
  text-transform: uppercase;
  color: var(--color-accent);
  margin-bottom: 1rem;
}
.page-header h1 { margin-bottom: 0.7rem; }
.page-sub {
  max-width: 760px;
  font-size: 0.98rem;
  color: var(--color-muted);
}
.research-grid {
  display: grid;
  grid-template-columns: 1fr;
  gap: 1.55rem;
  padding-bottom: 3.2rem;
  padding-inline: 2rem;
}
.research-card {
  min-height: 0;
  padding: 0 0 0 1rem;
  border: 0;
  border-left: 2px solid var(--color-border);
  border-radius: 0;
  background: transparent;
  box-shadow: none;
  display: flex;
  flex-direction: column;
  gap: 1rem;
}
.research-card h2 {
  font-size: 1rem;
  line-height: 1.3;
}
.research-card p {
  color: var(--color-muted);
  font-size: 0.94rem;
  line-height: 1.58;
}
@media (max-width: 850px) {
  .page-header,
  .research-grid { padding-inline: 0; }
}
</style>
