---
import Layout from '../layouts/Layout.astro';
import PublicationCard from '../components/PublicationCard.astro';
import { getCollection } from 'astro:content';

const pubs = await getCollection('publications');
const sorted = pubs.sort((a, b) => b.data.year - a.data.year);

const byYear = sorted.reduce((acc, p) => {
  const y = p.data.year;
  if (!acc[y]) acc[y] = [];
  acc[y].push(p);
  return acc;
}, {} as Record<number, typeof sorted>);

const years = Object.keys(byYear).map(Number).sort((a, b) => b - a);
---

<Layout title="Publications — Prithvi Rajan" description="Research publications by Prithvi Rajan in bioinformatics and data science.">
  <div class="container">
    <div class="page-header">
      <p class="eyebrow">Research</p>
      <h1>Publications <span class="accent">.</span></h1>
      <p class="page-sub">Research in structural bioinformatics, drug discovery, and data science. Reach out for collaboration or preprints.</p>
    </div>

    {years.length > 0 ? years.map(year => (
      <section class="year-section">
        <h2 class="year-heading">{year}</h2>
        <div class="pub-list">
          {byYear[year].map(pub => (
            <PublicationCard
              year={pub.data.year}
              title={pub.data.title}
              authors={pub.data.authors}
              journal={pub.data.journal}
              doi={pub.data.doi}
              paper_url={pub.data.paper_url}
              code_url={pub.data.code_url}
              abstract={pub.data.abstract}
              featured={pub.data.featured}
            />
          ))}
        </div>
      </section>
    )) : <p class="empty">Publications coming soon.</p>}
  </div>
</Layout>

<style>
.page-header {
  padding: 2.4rem 2rem 2rem;
  border-bottom: 1px solid var(--color-border);
  margin-bottom: 2.5rem;
}
.eyebrow {
  font-family: var(--font-sans);
  font-size: 0.76rem;
  font-weight: 600;
  letter-spacing: 0.08em;
  text-transform: uppercase;
  color: var(--color-accent);
  margin-bottom: 1rem;
}
.page-header h1 { margin-bottom: 0.7rem; }
.page-sub {
  max-width: 760px;
  font-size: 0.98rem;
  color: var(--color-muted);
}

.year-section {
  margin-bottom: 3.2rem;
  padding-inline: 2rem;
}

.year-heading {
  font-family: var(--font-heading);
  font-size: 1.05rem;
  font-weight: 800;
  color: var(--color-accent);
  margin-bottom: 1.55rem;
  padding-bottom: 0.5rem;
  border-bottom: 1px solid var(--color-border);
  text-transform: uppercase;
  letter-spacing: 0.04em;
}

.pub-list {
  display: flex;
  flex-direction: column;
  gap: 1.35rem;
  padding-bottom: 1rem;
}
.empty {
  color: var(--color-muted);
  font-style: italic;
  padding: 2rem;
  font-size: 0.98rem;
}

@media (max-width: 760px) {
  .page-header,
  .year-section,
  .empty { padding-inline: 0; }
}
</style>
