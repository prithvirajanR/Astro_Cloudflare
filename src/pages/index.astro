---
import Layout from '../layouts/Layout.astro';

const interests = [
  'structural bioinformatics and docking workflows',
  'healthcare data systems and decision dashboards',
  'computational biology with reproducible pipelines',
  'machine learning for biomedical questions',
];

const affiliations = [
  {
    name: 'Freie Universitaet Berlin',
    logo: '/logos/fu-berlin.svg',
    logoClass: 'logo-mark logo-fu',
  },
  {
    name: 'Kaiser Permanente',
    logo: '/logos/kaiser-permanente.svg',
    logoClass: 'logo-mark logo-kaiser',
  },
  {
    name: 'Accenture',
    logo: '/logos/accenture.svg',
    logoClass: 'logo-mark logo-accenture',
  },
  {
    name: 'Karunya University',
    logo: '/logos/karunya.png',
    logoClass: 'logo-mark logo-karunya',
  },
];

const timeline = [
  {
    period: '2024-present',
    title: 'M.Sc. Bioinformatics, Berlin',
    detail: 'Building a stronger bridge between database engineering, computational biology, and research-grade data workflows.',
  },
  {
    period: 'Jan-Jul 2024',
    title: 'Data Analyst, Accenture & Kaiser Permanente',
    detail: 'Analyzed hospital admissions and claims records, built Power BI dashboards, and shortened recurring report cycles with SQL pipelines.',
  },
  {
    period: '2021-2024',
    title: 'Oracle Database Administrator',
    detail: 'Worked across Oracle 11g to 19c migration, SQL optimization, Data Guard, and reliability practices for healthcare systems.',
  },
  {
    period: '2021',
    title: 'IBM DB2 Database Administrator',
    detail: 'Managed high-volume DB2 databases with a focus on performance, reliability, schema design, and secure operations.',
  },
];

const places = [
  { label: 'Berlin', x: 51, y: 31 },
  { label: 'Healthcare data', x: 26, y: 44 },
  { label: 'Life sciences', x: 63, y: 49 },
  { label: 'Open-source tools', x: 75, y: 35 },
];
---

<Layout title="Prithvi Rajan | Data Scientist and Bioinformatician">
  <div class="container hero-container">
    <section class="hero-section" aria-label="Introduction">
      <div class="hero-grid">
        <div class="hero-copy will-animate">
          <p class="section-kicker">Bioinformatics & Data Systems</p>
          <h1 class="hero-name">Prithvi Rajan</h1>
          <p class="hero-subtitle">Data Scientist | Bioinformatics MSc | Biomedical Data Systems</p>
          <p class="profile-location-text">Based in Berlin, Germany</p>

          <div class="intro-text">
            <p>
              I'm an <strong>MSc Bioinformatics student at Freie Universitaet Berlin</strong>, building research
              experience around the practical middle of bioinformatics: clean workflows, careful quality control,
              and results that other people can actually rerun.
            </p>

            <p>
              My work includes analysis pipelines and dashboards using <strong>Python</strong>, <strong>R</strong>,
              <strong>Snakemake</strong>, <strong>Docker</strong>, and SQL databases. I focus
              on connecting genomic, clinical, and environmental data responsibly to support precision medicine.
            </p>
          </div>

          <div class="social-actions" aria-label="Profile links">
            <a href="https://github.com/prithvirajanR" class="btn" target="_blank" rel="noopener">
              <span class="social-icon-wrapper" aria-hidden="true">
                <svg viewBox="0 0 24 24" width="16" height="16">
                  <path fill="currentColor" d="M12 2C6.48 2 2 6.58 2 12.22c0 4.52 2.87 8.35 6.84 9.7.5.1.68-.22.68-.49 0-.24-.01-1.04-.01-1.89-2.78.62-3.37-1.22-3.37-1.22-.46-1.19-1.11-1.5-1.11-1.5-.91-.64.07-.63.07-.63 1 .07 1.53 1.06 1.53 1.06.9 1.56 2.35 1.11 2.92.85.09-.66.35-1.11.63-1.36-2.22-.26-4.55-1.14-4.55-5.05 0-1.12.39-2.03 1.03-2.75-.1-.26-.45-1.31.1-2.71 0 0 .84-.27 2.75 1.05A9.34 9.34 0 0 1 12 6.94c.85 0 1.7.12 2.5.34 1.9-1.32 2.74-1.05 2.74-1.05.55 1.4.2 2.45.1 2.71.64.72 1.03 1.63 1.03 2.75 0 3.92-2.34 4.79-4.57 5.04.36.32.68.94.68 1.9 0 1.37-.01 2.47-.01 2.8 0 .27.18.59.69.49A10.1 10.1 0 0 0 22 12.22C22 6.58 17.52 2 12 2Z"/>
                </svg>
              </span>
              GitHub
            </a>
            <a href="https://www.linkedin.com/in/prithvi-rajan-925879256/" class="btn" target="_blank" rel="noopener">
              <span class="social-icon-wrapper" aria-hidden="true">
                <svg viewBox="0 0 24 24" width="16" height="16">
                  <path fill="currentColor" d="M5.2 8.8H2.4V21h2.8V8.8ZM3.8 3C2.8 3 2 3.78 2 4.75S2.78 6.5 3.76 6.5h.02c1.02 0 1.8-.78 1.8-1.75S4.8 3 3.8 3Zm7 5.8H8V21h2.8v-6.78c0-.36.03-.72.13-.98.3-.72.98-1.47 2.12-1.47 1.5 0 2.1 1.13 2.1 2.8V21H18v-6.75c0-3.62-1.93-5.3-4.5-5.3-2.1 0-3.02 1.16-3.53 1.97h.03V8.8Z"/>
                </svg>
              </span>
              LinkedIn
            </a>
            <a href="mailto:prithvi.rajan300@gmail.com" class="btn">
              <span class="social-icon-wrapper" aria-hidden="true">
                <svg viewBox="0 0 24 24" width="16" height="16">
                  <path fill="currentColor" d="M3.5 5h17A1.5 1.5 0 0 1 22 6.5v11a1.5 1.5 0 0 1-1.5 1.5h-17A1.5 1.5 0 0 1 2 17.5v-11A1.5 1.5 0 0 1 3.5 5Zm.7 2 7.8 5.45L19.8 7H4.2Zm15.8 1.85-7.43 5.19a1 1 0 0 1-1.14 0L4 8.85V17h16V8.85Z"/>
                </svg>
              </span>
              Email
            </a>
            <a href="/Prithivi_Rajan_CV.pdf" class="btn btn-solid" target="_blank" rel="noopener">
              Resume
            </a>
          </div>
        </div>

        <div class="hero-portrait-panel will-animate">
          <div class="portrait-field">
            <div class="photo-glow"></div>
            <img src="/prof_pic.jpg" alt="Prithvi Rajan portrait" class="profile-photo" loading="eager" />
          </div>
          <div class="interests-panel">
            <span class="interests-title">Core Focus Areas</span>
            <ul class="interests-list">
              {interests.map(item => <li>{item}</li>)}
            </ul>
          </div>
        </div>
      </div>

      <div class="affiliation-section">
        <p class="affiliation-kicker">Professional Affiliations</p>
        <div class="affiliation-strip">
          {affiliations.map(item => (
            <div class="affiliation-card will-animate" title={item.name}>
              <img
                src={item.logo}
                alt={item.name}
                class={item.logoClass}
                loading="lazy"
              />
            </div>
          ))}
        </div>
      </div>
    </section>

    <hr class="section-divider" />

    <section class="timeline-section" aria-labelledby="timeline-title">
      <p class="section-kicker">Experience & Education</p>
      <div class="section-header-row">
        <h2 id="timeline-title" class="section-title">Timeline</h2>
        <a href="/journey" class="btn">View full journey →</a>
      </div>
      
      <div class="timeline-list">
        {timeline.map(item => (
          <article class="timeline-item will-animate">
            <time>{item.period}</time>
            <div class="timeline-details">
              <h3 class="timeline-item-title">{item.title}</h3>
              <p>{item.detail}</p>
            </div>
          </article>
        ))}
      </div>
    </section>

    <hr class="section-divider" />

    <section class="map-section" aria-labelledby="map-title">
      <div class="map-container-inner">
        <div class="map-copy">
          <p class="section-kicker">Research geography</p>
          <h2 id="map-title" class="section-title">Building in Berlin. Contributing globally.</h2>
          <p class="map-desc">
            Collaborating across institutions and open science communities worldwide to
            advance reproducible, data-driven research.
          </p>
        </div>

        <div class="signal-map-wrapper will-animate">
          <div class="signal-map" aria-label="Stylized research map">
            <div class="map-gridlines"></div>
            {places.map(place => (
              <div class="map-point" style={`--x:${place.x}%; --y:${place.y}%`}>
                <span></span>
                <b>{place.label}</b>
              </div>
            ))}
          </div>
        </div>
      </div>
    </section>
  </div>
</Layout>

<style>
.hero-container {
  padding-top: 2.2rem;
}

.hero-section {
  padding-bottom: 2rem;
}

.hero-grid {
  display: grid;
  grid-template-columns: 1fr minmax(300px, 380px);
  gap: 3.5rem;
  align-items: start;
}

.hero-name {
  font-size: clamp(2.8rem, 6vw, 4rem);
  font-weight: 850;
  letter-spacing: -0.04em;
  margin-bottom: 0.2rem;
}

.hero-subtitle {
  font-size: 1.15rem;
  color: var(--color-accent);
  font-weight: 700;
  line-height: 1.35;
  margin-bottom: 0.6rem;
}

.profile-location-text {
  font-family: var(--font-mono);
  font-size: 0.8rem;
  color: var(--color-muted);
  font-weight: 600;
  display: flex;
  align-items: center;
  gap: 0.5rem;
  margin-bottom: 2rem;
}
.profile-location-text::before {
  content: '';
  display: block;
  width: 7px;
  height: 7px;
  border-radius: 50%;
  background: var(--color-accent);
  box-shadow: 0 0 0 3px var(--color-secondary-soft);
}

.intro-text {
  display: flex;
  flex-direction: column;
  gap: 1.25rem;
  max-width: 580px;
}
.intro-text p {
  font-size: 1.02rem;
  line-height: 1.68;
  color: var(--color-text);
}
.intro-text strong {
  color: var(--color-text);
  font-weight: 700;
}

.social-actions {
  display: flex;
  flex-wrap: wrap;
  gap: 0.75rem;
  margin-top: 2.2rem;
}
.social-icon-wrapper {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  color: currentColor;
  opacity: 0.8;
}

.hero-portrait-panel {
  display: flex;
  flex-direction: column;
  gap: 1.8rem;
}

.portrait-field {
  position: relative;
  width: 100%;
  aspect-ratio: 1 / 1.12;
  border-radius: 16px;
  overflow: visible;
}

.photo-glow {
  position: absolute;
  inset: -15px;
  background: radial-gradient(circle, rgba(var(--color-accent-rgb), 0.22) 0%, transparent 65%);
  z-index: 1;
  pointer-events: none;
  border-radius: 50%;
  filter: blur(10px);
  animation: floatGlow 8s infinite ease-in-out alternate;
}

@keyframes floatGlow {
  0% { transform: translate(0, 0) scale(1); }
  100% { transform: translate(10px, 10px) scale(1.1); }
}

.profile-photo {
  position: relative;
  z-index: 2;
  display: block;
  width: 100%;
  height: 100%;
  border-radius: 16px;
  object-fit: cover;
  object-position: center 36%;
  border: 1px solid var(--color-border);
  box-shadow: var(--shadow-card);
}

.interests-panel {
  background: var(--color-surface);
  border: 1px solid var(--color-border);
  border-radius: 12px;
  padding: 1.4rem;
  box-shadow: var(--shadow-card);
  transition: border-color 0.2s;
}
.interests-panel:hover {
  border-color: rgba(var(--color-accent-rgb), 0.2);
}
.interests-title {
  display: block;
  font-family: var(--font-mono);
  font-size: 0.76rem;
  font-weight: 800;
  text-transform: uppercase;
  color: var(--color-accent);
  margin-bottom: 0.8rem;
  letter-spacing: 0.06em;
}
.interests-list {
  list-style: none;
  display: flex;
  flex-direction: column;
  gap: 0.55rem;
}
.interests-list li {
  font-size: 0.9rem;
  line-height: 1.4;
  color: var(--color-muted);
  position: relative;
  padding-left: 0.9rem;
}
.interests-list li::before {
  content: '→';
  position: absolute;
  left: 0;
  color: var(--color-accent);
  font-weight: 700;
  font-size: 0.85rem;
}

.affiliation-section {
  margin-top: 3.5rem;
}
.affiliation-kicker {
  font-family: var(--font-mono);
  font-size: 0.72rem;
  font-weight: 700;
  letter-spacing: 0.04em;
  text-transform: uppercase;
  color: var(--color-muted);
  margin-bottom: 1.1rem;
}
.affiliation-strip {
  display: grid;
  grid-template-columns: repeat(4, minmax(0, 1fr));
  gap: 1.25rem;
}
.affiliation-card {
  display: grid;
  place-items: center;
  align-content: center;
  min-height: 96px;
  padding: 0.9rem;
  background: var(--color-surface);
  border: 1px solid var(--color-border);
  border-radius: 12px;
  box-shadow: var(--shadow-card);
  transition: all 0.25s cubic-bezier(0.4, 0, 0.2, 1);
}
.affiliation-card:hover {
  border-color: var(--color-accent);
  transform: translateY(-3px);
  box-shadow: var(--shadow-card-hover);
}
.affiliation-card img {
  display: block;
  width: 100%;
  height: auto;
  max-height: 44px;
  object-fit: contain;
  filter: grayscale(1) opacity(0.85);
  transition: filter 0.25s;
}
.dark .affiliation-card img {
  filter: grayscale(1) invert(1) opacity(0.85);
}
.affiliation-card:hover img {
  filter: grayscale(0) opacity(1);
}
.dark .affiliation-card:hover img {
  filter: grayscale(0) invert(0) opacity(1);
}

.section-header-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 1.5rem;
  margin-bottom: 2.2rem;
}
.section-header-row .section-title {
  margin-bottom: 0;
}

.timeline-section {
  padding-block: 1rem;
}

.timeline-list {
  position: relative;
  display: flex;
  flex-direction: column;
  gap: 0;
  padding-left: 1.8rem;
}
.timeline-list::before {
  content: '';
  position: absolute;
  top: 0.8rem;
  bottom: 0.8rem;
  left: 0.44rem;
  width: 2px;
  background: var(--color-border);
  transition: background 0.25s;
}

.timeline-item {
  position: relative;
  display: grid;
  grid-template-columns: 180px minmax(0, 1fr);
  gap: 1.5rem;
  align-items: start;
  padding-bottom: 2rem;
}
.timeline-item:last-child {
  padding-bottom: 0;
}

.timeline-item::before {
  content: '';
  position: absolute;
  top: 0.35rem;
  left: -1.8rem;
  width: 12px;
  height: 12px;
  border-radius: 50%;
  background: var(--color-bg);
  border: 3px solid var(--color-accent);
  box-shadow: 0 0 0 3px var(--color-secondary-soft);
  z-index: 2;
  transition: all 0.25s;
}
.timeline-item:hover::before {
  background: var(--color-accent);
  transform: scale(1.15);
}

.timeline-item time {
  font-family: var(--font-mono);
  color: var(--color-accent);
  font-size: 0.84rem;
  font-weight: 700;
  white-space: nowrap;
  padding-top: 1px;
}

.timeline-details {
  display: flex;
  flex-direction: column;
  gap: 0.22rem;
}

.timeline-item-title {
  font-family: var(--font-heading);
  font-size: 1.1rem;
  font-weight: 800;
  color: var(--color-text);
}

.timeline-item p {
  margin: 0;
  color: var(--color-muted);
  font-size: 0.94rem;
  line-height: 1.6;
}

.map-section {
  padding-block: 1rem;
}

.map-container-inner {
  display: grid;
  grid-template-columns: minmax(230px, 0.42fr) minmax(360px, 1fr);
  gap: 3.5rem;
  align-items: center;
}

.map-copy h2 {
  margin-bottom: 0.8rem;
}

.map-desc {
  color: var(--color-muted);
  font-size: 0.95rem;
  line-height: 1.6;
}

.signal-map-wrapper {
  background: var(--color-surface);
  border: 1px solid var(--color-border);
  border-radius: 16px;
  padding: 1.25rem;
  box-shadow: var(--shadow-card);
  transition: border-color 0.25s;
}
.signal-map-wrapper:hover {
  border-color: rgba(var(--color-accent-rgb), 0.2);
}

.signal-map {
  position: relative;
  min-height: 340px;
  overflow: hidden;
  background: var(--color-surface2);
  border-radius: 12px;
  border: 1px solid var(--color-border);
  transition: background 0.25s, border-color 0.25s;
}

.signal-map::before {
  content: '';
  position: absolute;
  inset: 18%;
  border: 1.5px dashed rgba(var(--color-accent-rgb), 0.22);
  border-radius: 50%;
  transform: rotate(-12deg) scaleX(1.35);
}

.signal-map::after {
  content: '';
  position: absolute;
  left: 18%;
  right: 14%;
  top: 52%;
  height: 1.5px;
  background: linear-gradient(90deg, transparent, rgba(var(--color-accent-rgb), 0.35), rgba(var(--color-accent-rgb), 0.05), transparent);
  transform: rotate(-8deg);
}

.map-gridlines {
  position: absolute;
  inset: 0;
  background-image:
    linear-gradient(rgba(var(--color-text-rgb), 0.02) 1px, transparent 1px),
    linear-gradient(90deg, rgba(var(--color-text-rgb), 0.02) 1px, transparent 1px);
  background-size: 32px 32px;
  opacity: 0.7;
}

.map-point {
  position: absolute;
  left: var(--x);
  top: var(--y);
  display: flex;
  align-items: center;
  gap: 0.55rem;
  transform: translate(-8px, -50%);
  color: var(--color-text);
  font-family: var(--font-heading);
  font-size: 0.78rem;
  font-weight: 800;
}

.map-point span {
  width: 10px;
  height: 10px;
  background: var(--color-accent);
  border-radius: 50%;
  box-shadow: 0 0 0 3px rgba(var(--color-accent-rgb), 0.22);
  position: relative;
  display: block;
}

.map-point span::after {
  content: '';
  position: absolute;
  inset: -4px;
  border-radius: 50%;
  border: 1px solid var(--color-accent);
  animation: pulseRing 1.8s infinite ease-out;
}

@keyframes pulseRing {
  0% { transform: scale(0.6); opacity: 1; }
  100% { transform: scale(2.2); opacity: 0; }
}

.map-point b {
  padding: 0.25rem 0.55rem;
  background: var(--color-surface);
  border: 1px solid var(--color-border);
  border-radius: 6px;
  box-shadow: 0 2px 5px rgba(0,0,0,0.03);
  font-size: 0.72rem;
  font-weight: 700;
  letter-spacing: -0.01em;
  white-space: nowrap;
}

@media (max-width: 900px) {
  .hero-grid,
  .map-container-inner {
    grid-template-columns: 1fr;
    gap: 2.5rem;
  }
  .hero-portrait-panel {
    max-width: 440px;
    margin-inline: auto;
    width: 100%;
  }
  .affiliation-strip {
    grid-template-columns: repeat(2, minmax(0, 1fr));
  }
}

@media (max-width: 700px) {
  .timeline-item {
    grid-template-columns: 1fr;
    gap: 0.35rem;
    padding-bottom: 1.75rem;
  }
  .timeline-item::before {
    top: 0.2rem;
  }
  .timeline-item time {
    font-size: 0.78rem;
  }
}

@media (max-width: 520px) {
  .affiliation-strip {
    grid-template-columns: 1fr;
  }
}
</style>
