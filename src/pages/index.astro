---
import Layout from '../layouts/Layout.astro';

const interests = [
  'structural bioinformatics and docking workflows',
  'healthcare data systems and decision dashboards',
  'computational biology with reproducible pipelines',
  'machine learning for biomedical questions',
];

const affiliations = [
  {
    name: 'Freie Universitaet Berlin',
    logo: '/logos/fu-berlin.svg',
    logoClass: 'logo-mark logo-fu',
  },
  {
    name: 'Kaiser Permanente',
    logo: '/logos/kaiser-permanente.svg',
    logoClass: 'logo-mark logo-kaiser',
  },
  {
    name: 'Accenture',
    logo: '/logos/accenture.svg',
    logoClass: 'logo-mark logo-accenture',
  },
  {
    name: 'Karunya University',
    logo: '/logos/karunya.png',
    logoClass: 'logo-mark logo-karunya',
  },
];

const timeline = [
  {
    period: '2024-present',
    title: 'M.Sc. Bioinformatics, Berlin',
    detail: 'Building a stronger bridge between database engineering, computational biology, and research-grade data workflows.',
  },
  {
    period: 'Jan-Jul 2024',
    title: 'Data Analyst, Accenture & Kaiser Permanente',
    detail: 'Analyzed hospital admissions and claims records, built Power BI dashboards, and shortened recurring report cycles with SQL pipelines.',
  },
  {
    period: '2021-2024',
    title: 'Oracle Database Administrator',
    detail: 'Worked across Oracle 11g to 19c migration, SQL optimization, Data Guard, and reliability practices for healthcare systems.',
  },
  {
    period: '2021',
    title: 'IBM DB2 Database Administrator',
    detail: 'Managed high-volume DB2 databases with a focus on performance, reliability, schema design, and secure operations.',
  },
];

const places = [
  { label: 'Berlin', x: 51, y: 31 },
  { label: 'Healthcare data', x: 26, y: 44 },
  { label: 'Life sciences', x: 63, y: 49 },
  { label: 'Open-source tools', x: 75, y: 35 },
];
---

<Layout title="Prithvi Rajan | Data Scientist and Bioinformatician">
  <div class="container profile-page">
    <section class="intro" aria-labelledby="intro-title">
      <div class="intro-grid">
        <div class="intro-copy">
          <h1 id="intro-title"><span>Prithvi</span> Rajan</h1>
          <p class="intro-subtitle">Data Scientist | Bioinformatics MSc | Biomedical Data Systems</p>

          <aside class="intro-aside" aria-label="Profile details">
            <img src="/prof_pic.jpg" alt="Prithvi Rajan" class="intro-photo" loading="eager" />
            <p class="profile-location">Berlin, Germany</p>

            <div class="social-row" aria-label="Profile links">
              <a href="https://github.com/prithvirajanR" class="social-link" target="_blank" rel="noopener">
                <span class="social-icon" aria-hidden="true">
                  <svg viewBox="0 0 24 24" role="img">
                    <path d="M12 2C6.48 2 2 6.58 2 12.22c0 4.52 2.87 8.35 6.84 9.7.5.1.68-.22.68-.49 0-.24-.01-1.04-.01-1.89-2.78.62-3.37-1.22-3.37-1.22-.46-1.19-1.11-1.5-1.11-1.5-.91-.64.07-.63.07-.63 1 .07 1.53 1.06 1.53 1.06.9 1.56 2.35 1.11 2.92.85.09-.66.35-1.11.63-1.36-2.22-.26-4.55-1.14-4.55-5.05 0-1.12.39-2.03 1.03-2.75-.1-.26-.45-1.31.1-2.71 0 0 .84-.27 2.75 1.05A9.34 9.34 0 0 1 12 6.94c.85 0 1.7.12 2.5.34 1.9-1.32 2.74-1.05 2.74-1.05.55 1.4.2 2.45.1 2.71.64.72 1.03 1.63 1.03 2.75 0 3.92-2.34 4.79-4.57 5.04.36.32.68.94.68 1.9 0 1.37-.01 2.47-.01 2.8 0 .27.18.59.69.49A10.1 10.1 0 0 0 22 12.22C22 6.58 17.52 2 12 2Z" />
                  </svg>
                </span>
                GitHub
              </a>
              <a href="https://www.linkedin.com/in/prithvi-rajan-925879256/" class="social-link" target="_blank" rel="noopener">
                <span class="social-icon" aria-hidden="true">
                  <svg viewBox="0 0 24 24" role="img">
                    <path d="M5.2 8.8H2.4V21h2.8V8.8ZM3.8 3C2.8 3 2 3.78 2 4.75S2.78 6.5 3.76 6.5h.02c1.02 0 1.8-.78 1.8-1.75S4.8 3 3.8 3Zm7 5.8H8V21h2.8v-6.78c0-.36.03-.72.13-.98.3-.72.98-1.47 2.12-1.47 1.5 0 2.1 1.13 2.1 2.8V21H18v-6.75c0-3.62-1.93-5.3-4.5-5.3-2.1 0-3.02 1.16-3.53 1.97h.03V8.8Z" />
                  </svg>
                </span>
                LinkedIn
              </a>
              <a href="mailto:prithvi.rajan300@gmail.com" class="social-link">
                <span class="social-icon" aria-hidden="true">
                  <svg viewBox="0 0 24 24" role="img">
                    <path d="M3.5 5h17A1.5 1.5 0 0 1 22 6.5v11a1.5 1.5 0 0 1-1.5 1.5h-17A1.5 1.5 0 0 1 2 17.5v-11A1.5 1.5 0 0 1 3.5 5Zm.7 2 7.8 5.45L19.8 7H4.2Zm15.8 1.85-7.43 5.19a1 1 0 0 1-1.14 0L4 8.85V17h16V8.85Z" />
                  </svg>
                </span>
                Email
              </a>
              <a href="/Prithivi_Rajan_CV.pdf" class="social-link" target="_blank" rel="noopener">
                <span class="social-icon" aria-hidden="true">
                  <svg viewBox="0 0 24 24" role="img">
                    <path d="M6 2.5h8.3L20 8.2v13.3H6V2.5Zm7.5 1.8V9h4.7l-4.7-4.7ZM8 4.5v15h10V11h-6.5V4.5H8Zm2 8.5h6v1.7h-6V13Zm0 3.3h6v1.7h-6v-1.7Z" />
                  </svg>
                </span>
                Resume
              </a>
            </div>
          </aside>

          <div class="interest-block" aria-label="Broad interests">
            <p>My broad interests:</p>
            <ul>
              {interests.map(item => <li>{item}</li>)}
            </ul>
          </div>

          <div class="bio-copy">
            <p>
              I'm an <strong>MSc Bioinformatics student at Freie Universitaet Berlin</strong>, building research
              experience around the practical middle of bioinformatics: clean workflows, careful quality control,
              and results that other people can actually rerun.
            </p>

            <p>
              My work includes analysis pipelines and dashboards using <strong>Python</strong>, <strong>R</strong>,
              <strong>Snakemake</strong>, <strong>Docker</strong>, and the command-line biology toolkit. I focus
              on connecting genomic, clinical, and environmental data responsibly to support precision medicine and discovery.
            </p>

            <p>
              Right now I'm strengthening my research practice across structural biology, statistical analysis, and
              workflow engineering while looking for projects where biology and computation meet in a useful, reproducible way.
            </p>
          </div>
        </div>
      </div>

      <div class="affiliation-strip" aria-label="Current institutions">
        {affiliations.map(item => (
          <div class="affiliation-card" title={item.name}>
            <img
              src={item.logo}
              alt={item.name}
              class={item.logoClass}
              loading="lazy"
            />
          </div>
        ))}
      </div>
    </section>

    <section class="timeline-section" aria-labelledby="timeline-title">
      <h2 id="timeline-title">Timeline</h2>
      <div class="timeline-list">
        {timeline.map(item => (
          <article class="timeline-item">
            <time>{item.period}</time>
            <div class="timeline-details">
              <h3 class="timeline-item-title">{item.title}</h3>
              <p>{item.detail}</p>
            </div>
          </article>
        ))}
      </div>
    </section>

    <section class="map-section" aria-labelledby="map-title">
      <div class="map-container-inner">
        <div class="map-copy">
          <p class="eyebrow">Research geography</p>
          <h2 id="map-title" class="section-title">Building in Berlin. Contributing globally.</h2>
          <p class="map-desc">
            Collaborating across institutions and open science communities worldwide to
            advance reproducible, data-driven research.
          </p>
        </div>

        <div class="signal-map will-animate" aria-label="Stylized research map">
          <div class="map-gridlines"></div>
          {places.map(place => (
            <div class="map-point" style={`--x:${place.x}%; --y:${place.y}%`}>
              <span></span>
              <b>{place.label}</b>
            </div>
          ))}
        </div>
      </div>
    </section>
  </div>
</Layout>

<style>
.profile-page {
  padding-top: 1.15rem;
}

.intro {
  padding: 1.55rem 2rem 0;
}

.intro-grid {
  display: flow-root;
}

.intro-copy {
  min-width: 0;
}

.intro h1 {
  margin-top: 0;
  margin-bottom: 0.45rem;
  font-size: clamp(2.1rem, 4.2vw, 2.65rem);
}

.intro h1 span {
  color: var(--color-text);
}

.intro-subtitle {
  margin-bottom: 1.35rem;
  font-size: 0.95rem;
  color: var(--color-text);
}

.interest-block {
  margin-bottom: 1.3rem;
}

.interest-block p {
  margin-bottom: 0.55rem;
}

.interest-block ul {
  margin-left: 1.35rem;
  color: var(--color-text);
}

.interest-block li {
  padding-left: 0.15rem;
}

.intro-aside {
  float: right;
  width: min(38%, 390px);
  min-width: 330px;
  margin: 0 0 1.45rem 2.75rem;
  padding-top: 0;
  text-align: center;
}

.intro-photo {
  display: block;
  width: 100%;
  max-width: 330px;
  aspect-ratio: 1 / 1.12;
  height: auto;
  margin-inline: auto;
  border-radius: 4px;
  object-fit: cover;
  object-position: center 36%;
  border: 1px solid var(--color-border);
  box-shadow: none;
}

.profile-location {
  margin-top: 1rem;
  font-weight: 700;
  color: var(--color-text);
}

.social-row {
  display: flex;
  flex-wrap: nowrap;
  justify-content: center;
  gap: 0.45rem;
  margin-top: 0.55rem;
  white-space: nowrap;
}

.social-link {
  display: inline-flex;
  align-items: center;
  gap: 0.28rem;
  color: var(--color-accent);
  font-size: 0.86rem;
  font-weight: 600;
}

.social-link + .social-link::before {
  content: '|';
  color: var(--color-border);
  margin-right: 0.1rem;
}

.social-icon {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  color: var(--color-muted);
  width: 1rem;
  height: 1rem;
  flex: 0 0 auto;
}

.social-icon svg {
  width: 100%;
  height: 100%;
  display: block;
  fill: currentColor;
}

.social-link:hover,
.social-link:hover .social-icon {
  color: var(--color-accent2);
}

.bio-copy {
  display: block;
  margin-top: 1.5rem;
}

.bio-copy p {
  margin: 0;
}

.bio-copy p + p {
  margin-top: 1.35rem;
}

.bio-copy strong {
  font-weight: 800;
  color: var(--color-accent);
}

.affiliation-strip {
  display: grid;
  grid-template-columns: repeat(4, minmax(0, 1fr));
  gap: 1rem;
  margin-top: 2.25rem;
  padding: 1rem 0 2.1rem;
  border-top: 1px solid var(--color-border);
  border-bottom: 1px solid var(--color-border);
}

.affiliation-card {
  display: grid;
  place-items: center;
  align-content: center;
  min-height: 100px;
  padding: 0.75rem;
  background: #ffffff;
  border: 1px solid var(--color-border);
  border-radius: 4px;
}

.affiliation-card img {
  display: block;
  width: 100%;
  height: auto;
  max-height: 54px;
  object-fit: contain;
}

.timeline-section {
  margin: 3.3rem 2rem 0;
  padding-top: 1.45rem;
  border-top: 1px solid var(--color-border);
}

.timeline-section h2 {
  margin-bottom: 1.55rem;
  font-size: clamp(1.55rem, 2.8vw, 2.15rem);
  font-weight: 500;
}

.timeline-list {
  position: relative;
  display: grid;
  gap: 1.55rem;
  padding-left: 1.65rem;
}

.timeline-list::before {
  content: '';
  position: absolute;
  top: 0.65rem;
  bottom: 0.65rem;
  left: 0.44rem;
  width: 2px;
  background: var(--color-border);
}

.timeline-item {
  position: relative;
  display: grid;
  grid-template-columns: 180px minmax(0, 1fr);
  gap: 1.3rem;
  align-items: baseline;
}

.timeline-item::before {
  content: '';
  position: absolute;
  top: 0.37rem;
  left: -1.65rem;
  width: 0.9rem;
  height: 0.9rem;
  border-radius: 50%;
  background: var(--color-accent);
  box-shadow: 0 0 0 5px var(--color-secondary-soft);
}

.timeline-item time {
  color: var(--color-text);
  font-size: 0.9rem;
  font-weight: 800;
  white-space: nowrap;
}

.timeline-details {
  display: flex;
  flex-direction: column;
  gap: 0.2rem;
}

.timeline-item-title {
  font-family: var(--font-heading);
  font-size: 1.05rem;
  font-weight: 800;
}

.timeline-item p {
  margin: 0;
  color: var(--color-muted);
  font-size: 0.94rem;
  line-height: 1.58;
}

.map-section {
  margin: 3.3rem 2rem 0;
  padding-top: 1.45rem;
  border-top: 1px solid var(--color-border);
}

.map-container-inner {
  display: grid;
  grid-template-columns: minmax(230px, 0.42fr) minmax(360px, 1fr);
  gap: clamp(2rem, 6vw, 4rem);
  align-items: center;
}

.eyebrow {
  font-family: var(--font-sans);
  font-size: 0.76rem;
  font-weight: 600;
  letter-spacing: 0.08em;
  text-transform: uppercase;
  color: var(--color-accent);
  margin-bottom: 0.8rem;
}

.map-copy h2 {
  margin-bottom: 0.8rem;
}

.map-desc {
  color: var(--color-muted);
  font-size: 0.94rem;
  line-height: 1.58;
}

.signal-map {
  position: relative;
  min-height: 330px;
  overflow: hidden;
  background: var(--color-bg);
  border: 1px solid var(--color-border);
  border-radius: 4px;
}

.signal-map::before {
  content: '';
  position: absolute;
  inset: 18%;
  border: 1px dashed color-mix(in oklch, var(--color-accent) 48%, transparent);
  border-radius: 50%;
  transform: rotate(-12deg) scaleX(1.35);
}

.signal-map::after {
  content: '';
  position: absolute;
  left: 18%;
  right: 14%;
  top: 52%;
  height: 1px;
  background: linear-gradient(90deg, transparent, color-mix(in oklch, var(--color-accent) 70%, transparent), color-mix(in oklch, var(--color-secondary) 70%, transparent), transparent);
  transform: rotate(-8deg);
}

.map-gridlines {
  position: absolute;
  inset: 0;
  background:
    linear-gradient(90deg, color-mix(in oklch, var(--color-border) 42%, transparent) 1px, transparent 1px),
    linear-gradient(0deg, color-mix(in oklch, var(--color-border) 42%, transparent) 1px, transparent 1px);
  background-size: 44px 44px;
  opacity: 0.2;
}

.map-point {
  position: absolute;
  left: var(--x);
  top: var(--y);
  display: flex;
  align-items: center;
  gap: 0.45rem;
  transform: translate(-12px, -50%);
  color: var(--color-text);
  font-family: var(--font-heading);
  font-size: 0.78rem;
  font-weight: 800;
}

.map-point span {
  width: 12px;
  height: 12px;
  background: var(--color-secondary);
  border: 2px solid var(--color-bg);
  border-radius: 50%;
}

.map-point b {
  padding: 0.22rem 0.42rem;
  background: var(--color-surface2);
  border: 1px solid var(--color-border);
  border-radius: 6px;
}

@media (max-width: 860px) {
  .intro-grid,
  .map-container-inner {
    grid-template-columns: 1fr;
  }

  .intro-aside {
    float: none;
    width: 100%;
    min-width: 0;
    margin: 0 0 1.8rem;
    padding-top: 0;
    text-align: left;
  }

  .intro-photo {
    margin-inline: 0;
  }

  .social-row {
    justify-content: flex-start;
    flex-wrap: wrap;
    white-space: normal;
  }

  .affiliation-strip {
    grid-template-columns: repeat(2, minmax(0, 1fr));
  }
}

@media (max-width: 700px) {
  .intro {
    padding-inline: 0;
  }

  .timeline-section,
  .map-section {
    margin-inline: 0;
  }

  .timeline-item {
    grid-template-columns: 1fr;
    gap: 0.3rem;
  }

  .signal-map {
    min-height: 300px;
  }
}

@media (max-width: 520px) {
  .affiliation-strip {
    grid-template-columns: 1fr;
  }
}
</style>
