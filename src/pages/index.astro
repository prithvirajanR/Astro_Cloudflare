---
import Layout from '../layouts/Layout.astro';

const interests = [
  'structural bioinformatics and docking workflows',
  'healthcare data systems and decision dashboards',
  'computational biology with reproducible pipelines',
  'machine learning for biomedical questions',
];

const skills = [
  'Python',
  'R',
  'SQL / PL/SQL',
  'Power BI',
  'Oracle 11g/19c',
  'IBM DB2',
  'ETL pipelines',
  'ESMFold',
  'GNINA',
  'AutoDock Vina',
  'Docker',
  'Linux / AIX',
];

const affiliations = [
  { name: 'Freie Universitaet Berlin', detail: 'M.Sc. Bioinformatics', mark: 'FU Berlin', tone: 'blue' },
  { name: 'Kaiser Permanente', detail: 'Healthcare data systems and analytics', mark: 'Kaiser', tone: 'blue' },
  { name: 'Accenture', detail: 'Data analysis and database administration', mark: 'Accenture', tone: 'purple' },
  { name: 'Karunya University', detail: 'B.Tech Biotechnology foundation', mark: 'Karunya', tone: 'green' },
];

const timeline = [
  {
    period: '2024-present',
    title: 'M.Sc. Bioinformatics, Berlin',
    detail: 'Building a stronger bridge between database engineering, computational biology, and research-grade data workflows.',
  },
  {
    period: 'Jan-Jul 2024',
    title: 'Data Analyst, Accenture and Kaiser Permanente',
    detail: 'Analyzed hospital admissions and claims records, built Power BI dashboards, and shortened recurring report cycles with SQL pipelines.',
  },
  {
    period: '2021-2024',
    title: 'Oracle Database Administrator',
    detail: 'Worked across Oracle 11g to 19c migration, SQL optimization, Data Guard, and reliability practices for healthcare systems.',
  },
  {
    period: '2021',
    title: 'IBM DB2 Database Administrator',
    detail: 'Managed high-volume DB2 databases with a focus on performance, reliability, schema design, and secure operations.',
  },
];

const places = [
  { label: 'Berlin', x: 51, y: 31 },
  { label: 'Healthcare data', x: 26, y: 44 },
  { label: 'Life sciences', x: 63, y: 49 },
  { label: 'Open-source tools', x: 75, y: 35 },
];
---

<Layout title="Prithvi Rajan | Data Scientist and Bioinformatician">
  <section class="hero">
    <div class="container-wide hero-grid">
      <div class="hero-copy will-animate">
        <h1>Prithvi Rajan</h1>
        <p class="hero-summary">Data Scientist | Bioinformatics MSc | Biomedical Data Systems</p>

        <p class="location-line">Berlin, Germany</p>

        <div class="action-row" aria-label="Profile links">
          <a href="https://github.com/prithvirajanR" target="_blank" rel="noopener"><span>G</span>GitHub</a>
          <a href="https://www.linkedin.com/in/prithvi-rajan-925879256/" target="_blank" rel="noopener"><span>in</span>LinkedIn</a>
          <a href="mailto:prithvi.rajan300@gmail.com"><span>@</span>Email</a>
          <a href="/Prithivi_Rajan_CV.pdf" target="_blank" rel="noopener"><span>CV</span>Resume</a>
        </div>

        <div class="interest-panel" aria-labelledby="interests-heading">
          <h2 id="interests-heading">My broad interests:</h2>
          <ul>
            {interests.map(item => <li>{item}</li>)}
          </ul>
        </div>

        <div class="intro-copy">
          <p>
            I'm an <strong>MSc Bioinformatics</strong> student at <strong>Freie Universitaet Berlin</strong>,
            building research experience around the practical middle of bioinformatics: clean workflows,
            careful quality control, and results that other people can actually rerun.
          </p>
          <p>
            My work includes analysis pipelines and dashboards using Python, R, Snakemake, Docker, and
            the command-line biology toolkit. I focus on connecting genomic, clinical, and environmental
            data responsibly to support precision medicine and discovery.
          </p>
          <p>
            Right now I'm strengthening my research practice across structural biology, statistical
            analysis, and workflow engineering while looking for projects where biology and computation
            meet in a useful, reproducible way.
          </p>
        </div>
      </div>

      <aside class="profile-panel will-animate" aria-label="Profile details">
        <div class="portrait-field">
          <img src="/prof_pic.jpg" alt="Portrait of Prithvi Rajan" class="profile-photo" loading="eager" />
        </div>
        <div class="profile-facts">
          <article>
            <span>Education</span>
            <p>MSc Bioinformatics<br />Freie Universitaet Berlin</p>
          </article>
          <article>
            <span>Research Focus</span>
            <p>Structural bioinformatics, computational biology, healthcare data systems</p>
          </article>
          <article>
            <span>Toolkit</span>
            <p>Python, R, Snakemake, Docker, SQL, Linux</p>
          </article>
        </div>
      </aside>
    </div>
  </section>

  <section class="affiliation-section">
    <div class="container affiliation-grid">
      {affiliations.map(item => (
        <article class={`affiliation-card ${item.tone} will-animate`}>
          <div class="affiliation-mark">{item.mark}</div>
          <p>{item.name}</p>
          <span>{item.detail}</span>
        </article>
      ))}
    </div>
  </section>

  <section class="section">
    <div class="container">
      <div class="section-head">
        <div>
          <h2 class="section-title">Timeline</h2>
        </div>
        <a href="/journey" class="text-link">View full journey</a>
      </div>

      <div class="timeline">
        {timeline.map(item => (
          <article class="timeline-item will-animate">
            <p class="timeline-period">{item.period}</p>
            <div>
              <h3>{item.title}</h3>
              <p>{item.detail}</p>
            </div>
          </article>
        ))}
      </div>
    </div>
  </section>

  <section class="section map-section">
    <div class="container map-grid">
      <div class="will-animate">
        <p class="section-kicker">Research geography</p>
        <h2 class="section-title">Building in Berlin. Contributing globally.</h2>
        <p>
          Collaborating across institutions and open science communities worldwide to
          advance reproducible, data-driven research.
        </p>
      </div>

      <div class="signal-map will-animate" aria-label="Stylized research map">
        <div class="map-gridlines"></div>
        {places.map(place => (
          <div class="map-point" style={`--x:${place.x}%; --y:${place.y}%`}>
            <span></span>
            <b>{place.label}</b>
          </div>
        ))}
      </div>
    </div>
  </section>
</Layout>

<style>
.hero {
  padding: clamp(2.8rem, 5vw, 4.4rem) 0 2.4rem;
}

.hero-grid {
  display: grid;
  grid-template-columns: minmax(0, 1fr) minmax(320px, 470px);
  gap: clamp(2rem, 6vw, 4.6rem);
  align-items: start;
}

.hero-copy h1 {
  margin: 0 0 0.45rem;
  font-family: var(--font-display);
  color: oklch(0.18 0.052 250);
  font-size: clamp(4rem, 7.4vw, 5.7rem);
  letter-spacing: -0.035em;
}

.hero-summary {
  max-width: 34rem;
  color: oklch(0.34 0.052 245);
  font-size: 1.35rem;
  line-height: 1.45;
}

.location-line {
  margin-top: 1.45rem;
  color: var(--color-text);
  font-size: 0.98rem;
}

.location-line::before {
  content: '';
  display: inline-block;
  width: 0.62rem;
  height: 0.62rem;
  margin-right: 0.55rem;
  border: 2px solid var(--color-blue);
  border-radius: 999px;
}

.action-row {
  display: flex;
  flex-wrap: wrap;
  align-items: center;
  gap: 0.55rem 1rem;
  margin-top: 1.3rem;
}

.action-row a {
  display: inline-flex;
  align-items: center;
  gap: 0.45rem;
  color: oklch(0.32 0.14 252);
  font-family: var(--font-heading);
  font-size: 0.86rem;
  font-weight: 700;
}

.action-row span {
  display: inline-grid;
  place-items: center;
  width: 24px;
  height: 24px;
  color: var(--color-blue);
  background: white;
  border: 1px solid var(--color-border);
  border-radius: 4px;
  font-size: 0.68rem;
}

.interest-panel {
  margin-top: 2.5rem;
  padding-top: 0;
  border-top: 0;
}

.interest-panel h2 {
  margin-bottom: 0.9rem;
  color: oklch(0.42 0.15 156);
  font-family: var(--font-heading);
  font-size: 0.82rem;
  text-transform: uppercase;
  letter-spacing: 0.08em;
}

.interest-panel ul {
  display: grid;
  gap: 0.45rem;
  padding-left: 1.1rem;
  color: oklch(0.23 0.035 245);
}

.interest-panel li::marker {
  color: var(--color-accent);
}

.intro-copy {
  display: grid;
  max-width: 34rem;
  gap: 1.25rem;
  margin-top: 1.6rem;
}

.intro-copy p {
  color: oklch(0.23 0.035 245);
  font-size: 0.98rem;
  line-height: 1.72;
}

.intro-copy p:first-child {
  padding-left: 1.35rem;
  border-left: 2px solid var(--color-accent);
}

.intro-copy strong {
  color: oklch(0.28 0.14 252);
}

.profile-panel {
  padding-top: 2.4rem;
  background:
    linear-gradient(90deg, color-mix(in oklch, var(--color-border) 36%, transparent) 1px, transparent 1px),
    linear-gradient(0deg, color-mix(in oklch, var(--color-border) 36%, transparent) 1px, transparent 1px);
  background-size: 22px 22px;
}

.portrait-field {
  position: relative;
  max-width: 420px;
  margin-left: auto;
}

.portrait-field::before,
.portrait-field::after {
  content: '';
  position: absolute;
  width: 32px;
  height: 32px;
  border-color: var(--color-accent);
  pointer-events: none;
}

.portrait-field::before {
  left: -10px;
  bottom: -10px;
  border-left: 3px solid var(--color-accent);
  border-bottom: 3px solid var(--color-accent);
}

.portrait-field::after {
  right: -10px;
  top: -10px;
  border-right: 3px solid var(--color-blue);
  border-top: 3px solid var(--color-blue);
}

.profile-photo {
  display: block;
  width: 100%;
  aspect-ratio: 1 / 1.12;
  object-fit: cover;
  border: 1px solid oklch(0.26 0.04 250);
  border-radius: 2px;
  box-shadow: 0 0 0 8px white;
  filter: grayscale(0.08) contrast(1.04);
}

.profile-facts {
  display: grid;
  gap: 1.25rem;
  width: min(330px, 86%);
  margin: 3.2rem auto 0;
}

.profile-facts article {
  padding-left: 3rem;
  position: relative;
}

.profile-facts article::before {
  content: '';
  position: absolute;
  left: 0.35rem;
  top: 0.2rem;
  width: 1.35rem;
  height: 1.35rem;
  border: 3px solid var(--color-blue);
  border-radius: 6px;
}

.profile-facts span {
  display: block;
  margin-bottom: 0.15rem;
  color: var(--color-text);
  font-family: var(--font-heading);
  font-size: 0.98rem;
  font-weight: 800;
}

.profile-facts p {
  color: oklch(0.32 0.045 245);
  font-size: 0.9rem;
  line-height: 1.5;
}

.affiliation-section {
  padding: 2rem 0 2.5rem;
  border-top: 1px solid var(--color-border);
  border-bottom: 1px solid var(--color-border);
}

.affiliation-grid {
  display: grid;
  grid-template-columns: repeat(4, minmax(0, 1fr));
  gap: 1.35rem;
}

.affiliation-card {
  min-height: 188px;
  padding: 1.35rem 1.45rem;
  background: white;
  border: 1px solid var(--color-border);
  border-radius: 3px;
}

.affiliation-mark {
  display: flex;
  align-items: center;
  min-height: 62px;
  color: oklch(0.33 0.14 252);
  font-family: var(--font-heading);
  font-size: 1.6rem;
  font-weight: 800;
  letter-spacing: -0.02em;
  border-bottom: 1px solid var(--color-border);
  margin-bottom: 1.25rem;
}

.affiliation-card.green .affiliation-mark {
  color: oklch(0.42 0.15 156);
}

.affiliation-card.purple .affiliation-mark {
  color: oklch(0.38 0.17 300);
}

.affiliation-card p {
  font-size: 0.98rem;
  margin-bottom: 0.15rem;
}

.affiliation-card span {
  color: oklch(0.32 0.045 245);
  font-size: 0.92rem;
}

.section-head {
  display: flex;
  align-items: end;
  justify-content: space-between;
  gap: 1.5rem;
  margin-bottom: 1.2rem;
}

.section-title {
  font-family: var(--font-display);
  font-size: clamp(2.4rem, 4.5vw, 3.4rem);
  font-weight: 600;
  letter-spacing: -0.035em;
}

.section-title::after {
  content: '';
  display: block;
  width: 54px;
  height: 2px;
  margin-top: 0.7rem;
  background: var(--color-accent);
}

.section-head .section-title::after {
  display: none;
}

.map-section .section-title {
  font-size: clamp(1.9rem, 3vw, 2.55rem);
  line-height: 1.14;
}

.map-section .section-title::after {
  display: block;
}

.text-link {
  color: var(--color-blue);
  font-family: var(--font-heading);
  font-size: 0.9rem;
  font-weight: 800;
}

.text-link:hover {
  color: var(--color-accent2);
}

.timeline {
  display: grid;
  gap: 0;
  position: relative;
  border-top: 0;
}

.timeline-item {
  display: grid;
  grid-template-columns: 250px minmax(0, 1fr);
  gap: 1.8rem;
  padding: 1.25rem 0 1.25rem 2rem;
  border-bottom: 1px solid var(--color-border);
  position: relative;
}

.timeline-item::before {
  content: '';
  position: absolute;
  left: 0;
  top: 1.6rem;
  width: 16px;
  height: 16px;
  background: var(--color-accent);
  border: 3px solid white;
  border-radius: 50%;
  box-shadow: 0 0 0 1px color-mix(in oklch, var(--color-accent) 65%, white);
}

.timeline-period {
  color: oklch(0.33 0.16 252);
  font-family: var(--font-heading);
  font-size: 0.86rem;
  font-weight: 800;
}

.timeline-item h3 {
  font-family: var(--font-heading);
  margin-bottom: 0.35rem;
}

.timeline-item p:last-child {
  color: var(--color-muted);
  max-width: 68ch;
}

.map-grid {
  display: grid;
  grid-template-columns: minmax(230px, 0.42fr) minmax(360px, 1fr);
  gap: clamp(2rem, 6vw, 4rem);
  align-items: center;
}

.map-grid p {
  color: var(--color-muted);
}

.signal-map {
  position: relative;
  min-height: 330px;
  overflow: hidden;
  background: white;
  border: 0;
  border-radius: 2px;
}

.signal-map::before {
  content: '';
  position: absolute;
  inset: 18%;
  border: 1px dashed color-mix(in oklch, var(--color-blue) 48%, transparent);
  border-radius: 50%;
  transform: rotate(-12deg) scaleX(1.35);
}

.signal-map::after {
  content: '';
  position: absolute;
  left: 18%;
  right: 14%;
  top: 52%;
  height: 1px;
  background: linear-gradient(90deg, transparent, color-mix(in oklch, var(--color-blue) 70%, transparent), color-mix(in oklch, var(--color-accent) 70%, transparent), transparent);
  transform: rotate(-8deg);
}

.map-gridlines {
  position: absolute;
  inset: 0;
  background:
    linear-gradient(90deg, color-mix(in oklch, var(--color-border) 42%, transparent) 1px, transparent 1px),
    linear-gradient(0deg, color-mix(in oklch, var(--color-border) 42%, transparent) 1px, transparent 1px);
  background-size: 44px 44px;
  opacity: 0.2;
}

.map-point {
  position: absolute;
  left: var(--x);
  top: var(--y);
  display: flex;
  align-items: center;
  gap: 0.45rem;
  transform: translate(-12px, -50%);
  color: var(--color-text);
  font-family: var(--font-heading);
  font-size: 0.78rem;
  font-weight: 800;
}

.map-point span {
  width: 12px;
  height: 12px;
  background: var(--color-accent);
  border: 2px solid white;
  border-radius: 50%;
}

.map-point b {
  padding: 0.22rem 0.42rem;
  background: color-mix(in oklch, white 86%, transparent);
  border: 1px solid color-mix(in oklch, var(--color-border) 70%, transparent);
  border-radius: 6px;
}

@media (max-width: 860px) {
  .hero-grid,
  .bio-grid,
  .map-grid {
    grid-template-columns: 1fr;
  }

  .profile-panel {
    max-width: 360px;
    padding-top: 1rem;
  }

  .affiliation-grid {
    grid-template-columns: 1fr;
  }
}

@media (max-width: 620px) {
  .hero-copy h1 {
    font-size: clamp(3.5rem, 18vw, 5rem);
  }

  .hero-summary {
    font-size: 1.08rem;
  }

  .section-head {
    align-items: flex-start;
    flex-direction: column;
  }

  .timeline-item {
    grid-template-columns: 1fr;
    gap: 0.4rem;
  }

  .signal-map {
    min-height: 300px;
  }
}
</style>
