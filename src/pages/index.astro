---
import Layout from '../layouts/Layout.astro';
const socialLinks = [
  { label: 'GitHub', href: 'https://github.com/prithvirajanR', icon: 'github' },
  { label: 'LinkedIn', href: 'https://www.linkedin.com/in/prithvi-rajan-925879256/', icon: 'linkedin' },
  { label: 'Email', href: 'mailto:prithvi.rajan300@gmail.com', icon: 'mail' },
  { label: 'Resume', href: '/Prithivi_Rajan_CV.pdf', icon: 'file' },
];

const broadInterests = [
  'structural bioinformatics and docking workflows',
  'healthcare data systems and decision dashboards',
  'computational biology with reproducible pipelines',
  'machine learning for biomedical questions',
];

const affiliations = [
  {
    name: 'Freie Universitat Berlin',
    href: 'https://www.fu-berlin.de/',
    logo: '/logos/fu-berlin.svg',
  },
  {
    name: 'Kaiser Permanente',
    href: 'https://healthy.kaiserpermanente.org/',
    logo: '/logos/kaiser-permanente.svg',
  },
  {
    name: 'Accenture',
    href: 'https://www.accenture.com/',
    logo: '/logos/accenture.svg',
  },
  {
    name: 'Karunya University',
    href: 'https://www.karunya.edu/',
    logo: '/logos/karunya.png',
  },
];

const timelineItems = [
  {
    date: '2024 - Present',
    text: 'Started the M.Sc. Bioinformatics program at Freie Universitat Berlin, building a stronger bridge between database engineering, computational biology, and research-grade workflows.',
  },
  {
    date: 'Jan - Jul 2024',
    text: 'Worked as a Data Analyst for Accenture and Kaiser Permanente projects, analyzing hospital admissions and claims records while building recurring Power BI and SQL reporting workflows.',
  },
  {
    date: '2021 - 2024',
    text: 'Worked as an Oracle Database Administrator across Oracle 11g to 19c migration, SQL optimization, Data Guard, and reliability practices for healthcare systems.',
  },
  {
    date: '2021',
    text: 'Managed high-volume IBM DB2 databases with focus on performance, schema design, secure operations, and production reliability.',
  },
  {
    date: 'Undergraduate',
    text: 'Completed a B.Tech Biotechnology foundation at Karunya University before moving deeper into computational biology and biomedical data systems.',
  },
];

const clustrMapsKey = import.meta.env.PUBLIC_CLUSTRMAPS_KEY || '';
const visitorMapEmbedSrc = import.meta.env.PUBLIC_VISITOR_MAP_EMBED_SRC || '';
const defaultVisitorMapSrc = '';
const clustrMapsSrc = clustrMapsKey
  ? `https://cdn.clustrmaps.com/map_v2.js?d=${encodeURIComponent(clustrMapsKey)}&cl=ffffff&w=a&t=n`
  : '';
const visitorMapSrc = visitorMapEmbedSrc || clustrMapsSrc || defaultVisitorMapSrc;

---

<Layout
  title="Prithvi Rajan - Bioinformatics MSc"
  description="Portfolio of Prithvi Rajan, an MSc Bioinformatics student in Berlin focused on structural bioinformatics, biomedical data systems, and reproducible computational biology workflows."
>
  <div class="container profile-page">
    <section class="intro" aria-labelledby="intro-title">
      <div class="intro-grid">
        <div class="intro-copy">
          <h1 id="intro-title"><span>Prithvi</span> Rajan</h1>
          <p class="intro-subtitle">Data Scientist | Bioinformatics MSc | Biomedical Data Systems</p>

          <aside class="intro-aside" aria-label="Profile details">
            <img src="/prof_pic.jpg" alt="Prithvi Rajan" class="intro-photo" loading="eager" />
            <p class="profile-location">Berlin, Germany</p>

            <div class="social-row" aria-label="Profile links">
              {socialLinks.map(link => (
                <a href={link.href} class="social-link" target={link.href.startsWith('http') ? '_blank' : undefined} rel={link.href.startsWith('http') ? 'noopener' : undefined}>
                  <span class="social-icon" aria-hidden="true">
                    {link.icon === 'github' && (
                      <svg viewBox="0 0 24 24" role="img">
                        <path d="M12 2C6.48 2 2 6.58 2 12.22c0 4.52 2.87 8.35 6.84 9.7.5.1.68-.22.68-.49 0-.24-.01-1.04-.01-1.89-2.78.62-3.37-1.22-3.37-1.22-.46-1.19-1.11-1.5-1.11-1.5-.91-.64.07-.63.07-.63 1 .07 1.53 1.06 1.53 1.06.9 1.56 2.35 1.11 2.92.85.09-.66.35-1.11.63-1.36-2.22-.26-4.55-1.14-4.55-5.05 0-1.12.39-2.03 1.03-2.75-.1-.26-.45-1.31.1-2.71 0 0 .84-.27 2.75 1.05A9.34 9.34 0 0 1 12 6.94c.85 0 1.7.12 2.5.34 1.9-1.32 2.74-1.05 2.74-1.05.55 1.4.2 2.45.1 2.71.64.72 1.03 1.63 1.03 2.75 0 3.92-2.34 4.79-4.57 5.04.36.32.68.94.68 1.9 0 1.37-.01 2.47-.01 2.8 0 .27.18.59.69.49A10.1 10.1 0 0 0 22 12.22C22 6.58 17.52 2 12 2Z" />
                      </svg>
                    )}
                    {link.icon === 'linkedin' && (
                      <svg viewBox="0 0 24 24" role="img">
                        <path d="M5.2 8.8H2.4V21h2.8V8.8ZM3.8 3C2.8 3 2 3.78 2 4.75S2.78 6.5 3.76 6.5h.02c1.02 0 1.8-.78 1.8-1.75S4.8 3 3.8 3Zm7 5.8H8V21h2.8v-6.78c0-.36.03-.72.13-.98.3-.72.98-1.47 2.12-1.47 1.5 0 2.1 1.13 2.1 2.8V21H18v-6.75c0-3.62-1.93-5.3-4.5-5.3-2.1 0-3.02 1.16-3.53 1.97h.03V8.8Z" />
                      </svg>
                    )}
                    {link.icon === 'mail' && (
                      <svg viewBox="0 0 24 24" role="img">
                        <path d="M3.5 5h17A1.5 1.5 0 0 1 22 6.5v11a1.5 1.5 0 0 1-1.5 1.5h-17A1.5 1.5 0 0 1 2 17.5v-11A1.5 1.5 0 0 1 3.5 5Zm.7 2 7.8 5.45L19.8 7H4.2Zm15.8 1.85-7.43 5.19a1 1 0 0 1-1.14 0L4 8.85V17h16V8.85Z" />
                      </svg>
                    )}
                    {link.icon === 'file' && (
                      <svg viewBox="0 0 24 24" role="img">
                        <path d="M6 2.5h8.3L20 8.2v13.3H6V2.5Zm7.5 1.8V9h4.7l-4.7-4.7ZM8 4.5v15h10V11h-6.5V4.5H8Zm2 8.5h6v1.7h-6V13Zm0 3.3h6v1.7h-6v-1.7Z" />
                      </svg>
                    )}
                  </span>
                  {link.label}
                </a>
              ))}
            </div>
          </aside>

          <div class="interest-block" aria-label="Broad interests">
            <p>My broad interests:</p>
            <ul>
              {broadInterests.map(item => <li>{item}</li>)}
            </ul>
          </div>

          <div class="bio-copy">
            <p>
              I'm an <strong>MSc Bioinformatics student at Freie Universitat Berlin</strong>, building research
              experience around the practical middle of bioinformatics: clean workflows, careful quality control,
              and results that other people can actually rerun.
            </p>

            <p>
              My work includes analysis pipelines and dashboards using <strong>Python</strong>, <strong>R</strong>,
              <strong>SQL</strong>, <strong>Snakemake</strong>, <strong>Docker</strong>, and the command-line biology
              toolkit. I focus on connecting genomic, clinical, and environmental data responsibly to support
              precision medicine and discovery.
            </p>

            <p>
              Right now I'm strengthening my research practice across structural biology, statistical analysis,
              and workflow engineering while looking for projects where biology and computation meet in a useful,
              reproducible way.
            </p>
          </div>
        </div>
      </div>

      <div class="affiliation-strip" aria-label="Current institutions">
        {affiliations.map(item => (
          <a
            href={item.href}
            class="affiliation-card"
            target="_blank"
            rel="noopener"
            aria-label={item.name}
          >
            <img
              src={item.logo}
              alt={item.name}
              loading="lazy"
            />
          </a>
        ))}
      </div>
    </section>

    <section class="timeline-section" aria-labelledby="timeline-title">
      <h2 id="timeline-title">Timeline</h2>
      <div class="timeline-list">
        {timelineItems.map(item => (
          <article class="timeline-item">
            <time>{item.date}</time>
            <p>{item.text}</p>
          </article>
        ))}
      </div>
    </section>

    <section class="visitor-map-section" aria-label="Recent visitor map" data-visitor-map-src={visitorMapSrc}>
      <div class="visitor-map-shell" id="visitor-map-shell">
        {visitorMapSrc ? (
          <div class="visitor-map-loading">Loading map...</div>
        ) : (
          <div class="visitor-map-placeholder">
            <span>ClustrMaps visitor map</span>
            <small>Add a visitor-map key to show live visits.</small>
          </div>
        )}
      </div>
    </section>
  </div>
</Layout>

<style>
.profile-page {
  padding-top: 1.15rem;
}

.intro {
  padding: 1.55rem 2rem 0;
}

.intro-grid {
  display: flow-root;
}

.intro-copy {
  min-width: 0;
}

.intro h1 {
  margin-top: 0;
  margin-bottom: 0.45rem;
  font-size: clamp(2.1rem, 4.2vw, 2.65rem);
}

.intro h1 span {
  color: var(--color-text);
}

.intro-subtitle {
  margin-bottom: 1.35rem;
  font-size: 0.95rem;
  color: var(--color-text);
}

.interest-block {
  margin-bottom: 1.3rem;
}

.interest-block p {
  margin-bottom: 0.55rem;
}

.interest-block ul {
  margin-left: 1.35rem;
  color: var(--color-text);
}

.interest-block li {
  padding-left: 0.15rem;
}

.intro-aside {
  float: right;
  width: min(38%, 390px);
  min-width: 330px;
  margin: 0 0 1.45rem 2.75rem;
  padding-top: 0;
  text-align: center;
}

.intro-photo {
  display: block;
  width: 100%;
  max-width: 330px;
  aspect-ratio: 1 / 1;
  height: auto;
  margin-inline: auto;
  border-radius: 3px;
  object-fit: cover;
  object-position: center 36%;
  border: 1px solid var(--color-border);
  box-shadow: none;
}

.profile-location {
  margin-top: 1rem;
  font-weight: 700;
  color: var(--color-text);
}

.social-row {
  display: flex;
  flex-wrap: nowrap;
  justify-content: center;
  gap: 0.45rem;
  margin-top: 0.55rem;
  white-space: nowrap;
}

.social-link {
  display: inline-flex;
  align-items: center;
  gap: 0.28rem;
  color: var(--color-accent);
  font-size: 0.86rem;
  font-weight: 600;
}

.social-link + .social-link::before {
  content: '|';
  color: var(--color-border);
  margin-right: 0.1rem;
}

.social-icon {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  color: var(--color-muted);
  width: 1rem;
  height: 1rem;
  flex: 0 0 auto;
}

.social-icon svg {
  width: 100%;
  height: 100%;
  display: block;
  fill: currentColor;
}

.social-link:hover,
.social-link:hover .social-icon {
  color: var(--color-accent2);
}

.bio-copy {
  display: block;
}

.bio-copy p {
  margin: 0;
}

.bio-copy p + p {
  margin-top: 1.35rem;
}

.bio-copy strong {
  font-weight: 800;
}

.affiliation-strip {
  display: grid;
  grid-template-columns: repeat(4, minmax(0, 1fr));
  gap: 1rem;
  margin-top: 2.25rem;
  padding: 1rem 0 2.1rem;
  border-top: 1px solid var(--color-border);
  border-bottom: 1px solid var(--color-border);
}

.affiliation-card {
  display: grid;
  place-items: center;
  align-content: center;
  min-height: 116px;
  padding: 0.75rem;
  background: #ffffff;
  border: 1px solid #dddddd;
  border-radius: 4px;
  transition: border-color 0.15s ease, transform 0.15s ease;
}

.dark .affiliation-card {
  background: #ffffff;
  border-color: #d8d8d8;
}

.affiliation-card:hover {
  border-color: var(--color-accent);
  transform: translateY(-1px);
}

.affiliation-card img {
  display: block;
  width: 100%;
  height: auto;
  max-height: 72px;
  object-fit: contain;
}

.affiliation-card:nth-child(2) img {
  max-width: 96%;
}

.affiliation-card:nth-child(4) img {
  max-height: 64px;
}

.timeline-section {
  margin: 3.3rem 2rem 0;
  padding-top: 1.45rem;
  border-top: 1px solid var(--color-border);
}

.timeline-section h2 {
  margin-bottom: 1.55rem;
  font-size: clamp(1.55rem, 2.8vw, 2.15rem);
  font-weight: 500;
}

.timeline-list {
  position: relative;
  display: grid;
  gap: 1.35rem;
  padding-left: 1.65rem;
}

.timeline-list::before {
  content: '';
  position: absolute;
  top: 0.65rem;
  bottom: 0.65rem;
  left: 0.44rem;
  width: 2px;
  background: var(--color-border);
}

.timeline-item {
  position: relative;
  display: grid;
  grid-template-columns: 180px minmax(0, 1fr);
  gap: 1.3rem;
  align-items: baseline;
}

.timeline-item::before {
  content: '';
  position: absolute;
  top: 0.37rem;
  left: -1.65rem;
  width: 0.9rem;
  height: 0.9rem;
  border-radius: 50%;
  background: var(--color-accent);
  box-shadow: 0 0 0 5px var(--color-secondary-soft);
}

.timeline-item time {
  color: var(--color-text);
  font-size: 0.9rem;
  font-weight: 800;
  white-space: nowrap;
}

.timeline-item p {
  margin: 0;
  color: var(--color-text);
  font-size: 0.98rem;
  line-height: 1.58;
}

.timeline-item strong,
.timeline-item a {
  color: var(--color-accent);
}

.visitor-map-section {
  margin: 3rem 2rem 0;
  padding-top: 1.35rem;
  border-top: 1px solid var(--color-border);
}

.visitor-map-shell {
  position: relative;
  width: 100%;
  min-height: 300px;
  overflow: hidden;
  background: #1f6fa8;
}

.visitor-map-shell :global(canvas),
.visitor-map-shell :global(iframe),
.visitor-map-shell :global(img),
.visitor-map-shell :global(a) {
  max-width: 100%;
}

.visitor-map-shell :global(#mapmyvisitors-widget) {
  width: 100% !important;
  max-width: 100% !important;
  margin: 0 auto !important;
}

.visitor-map-loading {
  min-height: 300px;
  display: grid;
  place-items: center;
  color: #ffffff;
}

.visitor-map-placeholder {
  width: 100%;
  min-height: 300px;
  display: grid;
  place-items: center;
  align-content: center;
  gap: 0.45rem;
  color: #ffffff;
  background: #1f6fa8;
  text-align: center;
}

.visitor-map-placeholder span {
  font-weight: 800;
}

.visitor-map-placeholder small {
  color: rgba(255, 255, 255, 0.82);
}

.visitor-map-placeholder code {
  color: #ffffff;
}

@media (max-width: 760px) {
  .intro-aside {
    float: none;
    width: 100%;
    min-width: 0;
    margin: 0 0 1.8rem;
    padding-top: 0;
    text-align: left;
  }

  .intro-photo {
    margin-inline: 0;
  }

  .social-row {
    justify-content: flex-start;
    flex-wrap: wrap;
    white-space: normal;
  }
}

@media (max-width: 700px) {
  .affiliation-strip {
    grid-template-columns: 1fr;
    gap: 0.9rem;
  }

  .timeline-item {
    grid-template-columns: 1fr;
    gap: 0.3rem;
  }

  .visitor-map-shell,
  .visitor-map-loading,
  .visitor-map-placeholder {
    min-height: 230px;
  }
}

@media (max-width: 560px) {
  .intro {
    padding-inline: 0;
  }

  .timeline-section {
    margin-inline: 0;
  }

  .visitor-map-section {
    margin-inline: 0;
  }
}
</style>
