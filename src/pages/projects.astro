---
import Layout from '../layouts/Layout.astro';
import ProjectCard from '../components/ProjectCard.astro';
import { getCollection } from 'astro:content';

const all = await getCollection('projects');
const sorted = all.sort((a, b) => a.data.order - b.data.order);
const featured = sorted.filter(p => p.data.featured);
const others   = sorted.filter(p => !p.data.featured);
---

<Layout title="Projects — Prithvi Rajan" description="Software and research projects by Prithvi Rajan.">
  <div class="container">
    <div class="page-header">
      <p class="eyebrow">Work</p>
      <h1>Projects <span class="accent">.</span></h1>
      <p class="page-sub">Research tools, data pipelines, and bioinformatics applications.</p>
    </div>

    {featured.length > 0 && (
      <section class="proj-section">
        <h2 class="proj-heading">Featured</h2>
        <div class="proj-grid">
          {featured.map(p => (
            <ProjectCard
              title={p.data.title}
              description={p.data.description}
              tags={p.data.tags}
              github={p.data.github}
              demo={p.data.demo}
              image={p.data.image}
              imageAlt={p.data.imageAlt}
              featured={p.data.featured}
            />
          ))}
        </div>
      </section>
    )}

    {others.length > 0 && (
      <section class="proj-section">
        <h2 class="proj-heading">Other Projects</h2>
        <div class="proj-grid">
          {others.map(p => (
            <ProjectCard
              title={p.data.title}
              description={p.data.description}
              tags={p.data.tags}
              github={p.data.github}
              demo={p.data.demo}
              image={p.data.image}
              imageAlt={p.data.imageAlt}
              featured={p.data.featured}
            />
          ))}
        </div>
      </section>
    )}
  </div>
</Layout>

<style>
.page-header {
  padding: 2.4rem 2rem 2rem;
  border-bottom: 1px solid var(--color-border);
  margin-bottom: 2.5rem;
}
.eyebrow {
  font-family: var(--font-sans);
  font-size: 0.76rem;
  font-weight: 600;
  letter-spacing: 0.08em;
  text-transform: uppercase;
  color: var(--color-accent);
  margin-bottom: 1rem;
}
.page-header h1 {
  margin-bottom: 0.7rem;
}
.page-sub {
  max-width: 760px;
  font-size: 0.98rem;
  color: var(--color-muted);
}
.proj-section {
  margin-bottom: 3.2rem;
}
.proj-heading {
  font-family: var(--font-heading);
  font-size: 1.05rem;
  font-weight: 800;
  color: var(--color-accent);
  margin-bottom: 1.55rem;
  padding-bottom: 0.5rem;
  border-bottom: 1px solid var(--color-border);
  text-transform: uppercase;
  letter-spacing: 0.04em;
  padding-inline: 2rem;
}
.proj-grid {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 1.35rem;
  padding-bottom: 1rem;
  padding-inline: 2rem;
}
@media (max-width: 760px) {
  .page-header,
  .proj-heading,
  .proj-grid { padding-inline: 0; }
  .proj-grid { grid-template-columns: 1fr; }
}
</style>
