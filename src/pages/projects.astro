---
import Layout from '../layouts/Layout.astro';
import ProjectCard from '../components/ProjectCard.astro';
import { getCollection } from 'astro:content';

const all = await getCollection('projects');
const sorted = all.sort((a, b) => a.data.order - b.data.order);
const featured = sorted.filter(p => p.data.featured);
const others   = sorted.filter(p => !p.data.featured);
---

<Layout title="Projects — Prithvi Rajan" description="Software and research projects by Prithvi Rajan.">
  <div class="container">
    <div class="page-header">
      <h1>Projects <span class="accent">.</span></h1>
      <p class="page-sub">Research tools, data pipelines, and bioinformatics applications.</p>
    </div>

    {featured.length > 0 && (
      <section class="proj-section">
        <h2 class="proj-heading">Featured</h2>
        <div class="proj-list">
          {featured.map(p => (
            <ProjectCard title={p.data.title} description={p.data.description}
              tags={p.data.tags} github={p.data.github} demo={p.data.demo} featured={p.data.featured} />
          ))}
        </div>
      </section>
    )}

    {others.length > 0 && (
      <section class="proj-section">
        <h2 class="proj-heading">Other Projects</h2>
        <div class="proj-list">
          {others.map(p => (
            <ProjectCard title={p.data.title} description={p.data.description}
              tags={p.data.tags} github={p.data.github} demo={p.data.demo} featured={p.data.featured} />
          ))}
        </div>
      </section>
    )}
  </div>
</Layout>

<style>
.page-header { padding: 4rem 0 3rem; border-bottom: 1px solid var(--color-border); margin-bottom: 3rem; }
.page-header h1 { margin-bottom: 0.5rem; }
.page-sub { font-size: 1.05rem; color: var(--color-muted); }

.proj-section { margin-bottom: 3rem; }
.proj-heading {
  font-family: var(--font-heading); font-size: 1.5rem; font-weight: 800;
  color: var(--color-accent); margin-bottom: 1.25rem;
  padding-bottom: 0.5rem; border-bottom: 1px solid var(--color-border);
}
.proj-list { display: flex; flex-direction: column; gap: 1.1rem; padding-bottom: 1rem; }
</style>
