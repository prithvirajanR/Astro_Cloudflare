---
import Layout from '../layouts/Layout.astro';

const education = [
  {
    period: 'Oct 2024 - Present',
    role: 'M.Sc. Bioinformatics',
    org: 'Freie Universitat Berlin',
    bullets: [
      'Coursework and research interests across structural biology, medical bioinformatics, machine learning, and biomedical data systems.',
      'Expected graduation: Oct 2026.',
    ],
  },
  {
    period: 'Completed',
    role: 'B.Tech Biotechnology',
    org: 'Karunya University',
    bullets: [
      'Built a foundation in biological sciences, biotechnology, and applied computational thinking.',
      'Moved toward computational biology, database systems, and data-driven biomedical workflows.',
    ],
  },
];

const experience = [
  {
    period: 'Jan 2024 - Jul 2024',
    role: 'Data Analyst',
    org: 'Accenture and Kaiser Permanente',
    bullets: [
      'Analyzed hospital admission and claims records for healthcare reporting workflows.',
      'Built Power BI dashboards and SQL pipelines that improved recurring report turnaround.',
    ],
  },
  {
    period: '2021 - 2024',
    role: 'Oracle Database Administrator',
    org: 'Healthcare data systems',
    bullets: [
      'Worked across Oracle 11g to 19c migration, SQL optimization, Data Guard, and production reliability.',
      'Supported healthcare database operations with attention to data integrity, security, and performance.',
    ],
  },
  {
    period: '2021',
    role: 'IBM DB2 Database Administrator',
    org: 'Enterprise database operations',
    bullets: [
      'Managed high-volume DB2 databases with a focus on performance, reliability, schema design, and secure operations.',
    ],
  },
];

const skills = [
  { cat: 'Languages', items: 'Python, R, SQL / PL/SQL, Bash, JavaScript, HTML/CSS' },
  { cat: 'Workflow Engineering', items: 'Snakemake, Docker, Linux, conda environments, reproducible reports' },
  { cat: 'Structural Biology', items: 'ESMFold, GNINA, AutoDock Vina, molecular docking workflows, protein structure prediction' },
  { cat: 'Data Systems', items: 'Oracle 11g/19c, IBM DB2, ETL pipelines, query optimization, Data Guard' },
  { cat: 'Analytics', items: 'Power BI, healthcare analytics, dashboarding, statistical analysis, exploratory visualization' },
  { cat: 'Research Practice', items: 'Computational biology, workflow documentation, version control, reproducible analysis' },
];
---

<Layout title="Journey - Prithvi Rajan" description="Education, experience, skills, and certifications of Prithvi Rajan.">
  <div class="container">
    <div class="page-header">
      <p class="eyebrow">Profile</p>
      <h1>My Journey <span class="accent">.</span></h1>
      <p class="page-sub">
        Education, database engineering experience, and technical skills in bioinformatics.
      </p>
      <a href="/Prithivi_Rajan_CV.pdf" target="_blank" rel="noopener" class="btn btn-solid">Download CV</a>
    </div>

    <section class="j-section">
      <h2 class="section-title">Education</h2>
      <div class="entry-list">
        {education.map(e => (
          <article class="entry-card will-animate">
            <div class="entry-meta"><span class="entry-period">{e.period}</span></div>
            <div class="entry-body">
              <h3 class="entry-role">{e.role}</h3>
              <p class="entry-org">{e.org}</p>
              <ul class="entry-bullets">{e.bullets.map(b => <li>{b}</li>)}</ul>
            </div>
          </article>
        ))}
      </div>
    </section>

    <section class="j-section">
      <h2 class="section-title">Experience</h2>
      <div class="entry-list">
        {experience.map(e => (
          <article class="entry-card will-animate">
            <div class="entry-meta"><span class="entry-period">{e.period}</span></div>
            <div class="entry-body">
              <h3 class="entry-role">{e.role}</h3>
              <p class="entry-org">{e.org}</p>
              <ul class="entry-bullets">{e.bullets.map(b => <li>{b}</li>)}</ul>
            </div>
          </article>
        ))}
      </div>
    </section>

    <section class="j-section">
      <h2 class="section-title">Skills</h2>
      <div class="skills-table will-animate">
        {skills.map(s => (
          <div class="skill-row">
            <span class="skill-cat">{s.cat}</span>
            <span class="skill-items">{s.items}</span>
          </div>
        ))}
      </div>
    </section>
  </div>
</Layout>

<style>
.page-header {
  padding: 2.4rem 2rem 2rem;
  border-bottom: 1px solid var(--color-border);
  margin-bottom: 2.5rem;
}
.eyebrow {
  font-family: var(--font-sans);
  font-size: 0.76rem;
  font-weight: 600;
  letter-spacing: 0.08em;
  text-transform: uppercase;
  color: var(--color-accent);
  margin-bottom: 1rem;
}
.page-header h1 { margin-bottom: 0.7rem; }
.page-sub {
  max-width: 760px;
  font-size: 0.98rem;
  color: var(--color-muted);
  margin-bottom: 1.35rem;
}
.j-section {
  padding: 0 2rem 3.2rem;
}
.entry-list {
  display: flex;
  flex-direction: column;
  gap: 1.55rem;
}
.entry-card {
  display: grid;
  grid-template-columns: 185px 1fr;
  gap: 1.5rem;
  padding: 0 0 0 1rem;
  background: transparent;
  border: 0;
  border-left: 2px solid var(--color-border);
  border-radius: 0;
  box-shadow: none;
}
.entry-period {
  font-family: var(--font-sans);
  font-size: 0.76rem;
  font-weight: 600;
  color: var(--color-muted);
  display: block;
  padding-top: 0.25rem;
  text-transform: uppercase;
}
.entry-role {
  font-size: 1rem;
  line-height: 1.3;
  margin-bottom: 0.2rem;
}
.entry-org {
  font-family: var(--font-sans);
  font-size: 0.92rem;
  font-weight: 700;
  color: var(--color-muted);
  margin-bottom: 0.75rem;
}
.entry-bullets {
  list-style: none;
  display: flex;
  flex-direction: column;
  gap: 0.42rem;
}
.entry-bullets li {
  position: relative;
  padding-left: 1rem;
  color: var(--color-muted);
  font-size: 0.94rem;
  line-height: 1.58;
}
.entry-bullets li::before {
  content: '';
  position: absolute;
  left: 0;
  top: 0.72em;
  width: 5px;
  height: 5px;
  border-radius: 50%;
  background: var(--color-border);
}
.skills-table {
  background: transparent;
  border: 0;
  border-top: 1px solid var(--color-border);
  border-radius: 4px;
  box-shadow: none;
  overflow: hidden;
}
.skill-row {
  display: grid;
  grid-template-columns: 200px 1fr;
  gap: 1rem;
  padding: 1rem 1.2rem;
  border-bottom: 1px solid var(--color-border);
}
.skill-row:last-child { border-bottom: none; }
.skill-cat {
  font-family: var(--font-sans);
  font-size: 0.82rem;
  font-weight: 650;
  color: var(--color-muted);
}
.skill-items {
  font-size: 0.93rem;
  color: var(--color-muted);
  line-height: 1.55;
}
@media (max-width: 850px) {
  .page-header,
  .j-section {
    padding-inline: 0;
  }
  .entry-card,
  .skill-row {
    grid-template-columns: 1fr;
  }
}
</style>
