---
import Layout from '../layouts/Layout.astro';

const education = [
  { period:'Oct 2024 – Present', role:'M.Sc. Bioinformatics', org:'Freie Universität Berlin',
    bullets:['Focus: Computational Biology, Structural Bioinformatics, Drug Discovery','Coursework: Statistical Modeling, Machine Learning, Algorithm Development'] },
  { period:'Jul 2016 – Oct 2020', role:'B.Tech Bioinformatics', org:'Karunya Institute of Technology and Sciences',
    bullets:['Python, IBM DB2, Oracle RDBMS, R programming','Virtual molecular screening, 3D QSAR, Molecular dynamics simulation, Toxicity analysis'] },
];

const experience = [
  { period:'Jan – Jul 2024', role:'Data Analyst', org:'Accenture · Kaiser Permanente',
    bullets:['Analyzed 100,000+ hospital records to identify patient behavior trends.','Built Power BI dashboards improving data-driven decision-making.','Engineered SQL pipelines cutting report turnaround by 30%.','Identified cost-saving opportunities via patient segmentation.'] },
  { period:'Dec 2021 – Jan 2024', role:'Oracle Database Administrator', org:'Accenture · Kaiser Permanente',
    bullets:['Led Oracle 11g → 19c migration with 100% data integrity and zero downtime.','Reduced application latency by 20% through SQL optimization.','Designed Oracle Data Guard disaster recovery for 24/7 operations.','Managed patch management, access controls, and security audits.'] },
  { period:'Feb – Sept 2021', role:'IBM DB2 Database Administrator', org:'Accenture · Kaiser Permanente',
    bullets:['Managed high-volume IBM DB2 databases for performance and reliability.','Designed normalized schemas and optimized indexes.','Led OS-level upgrades and planned capacity expansion.'] },
];

const skills = [
  { cat:'Languages',      items:'Python, Pandas, NumPy, R, SQL, PL/SQL' },
  { cat:'Databases',      items:'Oracle 11g/19c, IBM DB2, PostgreSQL' },
  { cat:'BI & Analytics', items:'Power BI, ETL Pipelines, Data Visualization' },
  { cat:'Bioinformatics', items:'ESMFold, GNINA, AutoDock Vina, MD Simulation' },
  { cat:'DevOps & Cloud', items:'Linux, AIX, Git, Docker, Cloudflare' },
  { cat:'Machine Learning',items:'scikit-learn, Classification, Regression, Clustering' },
];

const interests = ['Badminton','Gaming','Tech Exploration','Drug Discovery','Structural Biology'];
---

<Layout title="Journey — Prithvi Rajan" description="Full CV — education, experience, and skills of Prithvi Rajan.">
  <div class="container journey-container">
    <div class="page-header">
      <p class="eyebrow">Profile</p>
      <h1>My Journey <span class="accent">.</span></h1>
      <p class="page-sub">My professional path through database engineering, data systems, and bioinformatics.</p>
      <a href="/Prithivi_Rajan_CV.pdf" target="_blank" class="btn btn-solid">Download CV</a>
    </div>

    <section class="j-section">
      <h2 class="section-title">Education</h2>
      <div class="entry-list">
        {education.map(e => (
          <article class="entry-card will-animate">
            <div class="entry-meta"><span class="entry-period">{e.period}</span></div>
            <div class="entry-body">
              <h3 class="entry-role">{e.role}</h3>
              <p class="entry-org">{e.org}</p>
              <ul class="entry-bullets">{e.bullets.map(b => <li>{b}</li>)}</ul>
            </div>
          </article>
        ))}
      </div>
    </section>

    <section class="j-section">
      <h2 class="section-title">Experience</h2>
      <div class="entry-list">
        {experience.map(e => (
          <article class="entry-card will-animate">
            <div class="entry-meta"><span class="entry-period">{e.period}</span></div>
            <div class="entry-body">
              <h3 class="entry-role">{e.role}</h3>
              <p class="entry-org">{e.org}</p>
              <ul class="entry-bullets">{e.bullets.map(b => <li>{b}</li>)}</ul>
            </div>
          </article>
        ))}
      </div>
    </section>

    <section class="j-section">
      <h2 class="section-title">Skills & Toolkit</h2>
      <div class="skills-grid">
        {skills.map(s => (
          <div class="skill-group-card will-animate">
            <h3 class="skill-group-title">{s.cat}</h3>
            <div class="skill-group-items">
              {s.items.split(', ').map(item => <span class="tag">{item}</span>)}
            </div>
          </div>
        ))}
      </div>
    </section>

    <section class="j-section">
      <h2 class="section-title">Interests</h2>
      <div class="interests will-animate">
        {interests.map(i => <span class="interest-tag">{i}</span>)}
      </div>
    </section>
  </div>
</Layout>

<style>
.journey-container {
  padding-top: 2.2rem;
}

.page-header {
  padding: 2.4rem 2rem 2rem;
  border-bottom: 1px solid var(--color-border);
  margin-bottom: 3rem;
}
.eyebrow {
  font-family: var(--font-mono);
  font-size: 0.76rem;
  font-weight: 600;
  letter-spacing: 0.08em;
  text-transform: uppercase;
  color: var(--color-accent);
  margin-bottom: 1rem;
}
.page-header h1 { margin-bottom: 0.7rem; }
.page-sub {
  max-width: 760px;
  font-size: 0.98rem;
  color: var(--color-muted);
  margin-bottom: 1.45rem;
}

.j-section {
  padding: 0 2rem 3.5rem;
}

.section-title {
  margin-bottom: 1.8rem;
  font-size: clamp(1.4rem, 2.5vw, 1.8rem);
  font-weight: 800;
  letter-spacing: -0.02em;
}

.entry-list {
  display: flex;
  flex-direction: column;
  gap: 1.55rem;
}
.entry-card {
  display: grid;
  grid-template-columns: 185px 1fr;
  gap: 1.5rem;
  padding: 1.6rem 1.8rem;
  background: var(--color-surface);
  border: 1px solid var(--color-border);
  border-radius: 12px;
  box-shadow: var(--shadow-card);
  transition: all 0.25s cubic-bezier(0.4, 0, 0.2, 1);
  position: relative;
  overflow: hidden;
}
.entry-card::before {
  content: '';
  position: absolute;
  top: 0;
  bottom: 0;
  left: 0;
  width: 4px;
  background: var(--color-accent);
  opacity: 0;
  transition: opacity 0.2s ease;
}
.entry-card:hover {
  border-color: var(--color-accent);
  transform: translateY(-3px);
  box-shadow: var(--shadow-card-hover);
}
.entry-card:hover::before {
  opacity: 1;
}

.entry-period {
  font-family: var(--font-mono);
  font-size: 0.76rem;
  font-weight: 700;
  color: var(--color-accent);
  display: block;
  padding-top: 0.25rem;
  text-transform: uppercase;
}
.entry-role {
  font-size: 1.12rem;
  line-height: 1.25;
  font-weight: 800;
  margin-bottom: 0.25rem;
}
.entry-org {
  font-size: 0.94rem;
  font-weight: 600;
  color: var(--color-muted);
  margin-bottom: 0.85rem;
}
.entry-bullets {
  list-style: none;
  display: flex;
  flex-direction: column;
  gap: 0.45rem;
}
.entry-bullets li {
  position: relative;
  padding-left: 1.1rem;
  color: var(--color-muted);
  font-size: 0.94rem;
  line-height: 1.6;
}
.entry-bullets li::before {
  content: '';
  position: absolute;
  left: 0;
  top: 0.72em;
  width: 5px;
  height: 5px;
  border-radius: 50%;
  background: var(--color-border);
  transition: background 0.2s;
}
.entry-card:hover .entry-bullets li::before {
  background: var(--color-accent);
}

.skills-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 1.35rem;
}
.skill-group-card {
  background: var(--color-surface);
  border: 1px solid var(--color-border);
  border-radius: 12px;
  padding: 1.5rem;
  box-shadow: var(--shadow-card);
  transition: all 0.25s cubic-bezier(0.4, 0, 0.2, 1);
}
.skill-group-card:hover {
  border-color: var(--color-accent);
  transform: translateY(-2px);
  box-shadow: var(--shadow-card-hover);
}
.skill-group-title {
  font-family: var(--font-mono);
  font-size: 0.76rem;
  font-weight: 800;
  text-transform: uppercase;
  color: var(--color-accent);
  margin-bottom: 1rem;
  letter-spacing: 0.06em;
}
.skill-group-items {
  display: flex;
  flex-wrap: wrap;
  gap: 0.45rem;
}

.interests {
  display: flex;
  flex-wrap: wrap;
  gap: 0.4rem 1.4rem;
}
.interest-tag {
  font-family: var(--font-mono);
  font-size: 0.9rem;
  color: var(--color-muted);
  font-weight: 600;
}
.interest-tag::before {
  content: '#';
  color: var(--color-accent);
  margin-right: 0.2rem;
}

@media (max-width: 850px) {
  .page-header,
  .j-section {
    padding-inline: 0;
  }
  .entry-card {
    grid-template-columns: 1fr;
    gap: 0.6rem;
    padding: 1.4rem;
  }
  .skills-grid {
    grid-template-columns: 1fr;
  }
}
</style>
