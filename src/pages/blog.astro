---
import Layout from '../layouts/Layout.astro';
import BlogCard from '../components/BlogCard.astro';
import { getCollection } from 'astro:content';

const posts = await getCollection('blog');
const sorted = posts.sort((a, b) => a.data.order - b.data.order);
---

<Layout
  title="Blog - Prithvi Rajan"
  description="Technical articles by Prithvi Rajan on bioinformatics, machine learning, molecular docking, and reproducible genomics workflows."
>
  <div class="container">
    <div class="page-header">
      <h1>Blog <span class="accent">.</span></h1>
      <p class="page-sub">
        Technical notes from projects I built: what problem each repo solved, how the workflow was designed, and what the results showed.
      </p>
    </div>

    <section class="blog-grid" aria-label="Blog articles">
      {sorted.map((post) => (
        <BlogCard
          title={post.data.title}
          description={post.data.description}
          href={`/blog/${post.id}`}
          date={post.data.date}
          tags={post.data.tags}
          repo={post.data.repo}
          github={post.data.github}
          readingTime={post.data.readingTime}
          featured={post.data.featured}
        />
      ))}
    </section>
  </div>
</Layout>

<style>
.page-header {
  padding: 4rem 0 3rem;
  border-bottom: 1px solid var(--color-border);
  margin-bottom: 3rem;
}

.page-header h1 {
  margin-bottom: 0.5rem;
}

.page-sub {
  font-size: 1.05rem;
  color: var(--color-muted);
  max-width: 720px;
}

.blog-grid {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 1.1rem;
  padding-bottom: 2rem;
}

@media (max-width: 780px) {
  .blog-grid {
    grid-template-columns: 1fr;
  }
}
</style>
