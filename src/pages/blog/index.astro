---
import Layout from '../../layouts/Layout.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog'))
  .filter(post => !post.data.draft)
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());

const formatDate = (date: Date) =>
  new Intl.DateTimeFormat('en', {
    year: 'numeric',
    month: 'long',
    day: 'numeric',
  }).format(date);
---

<Layout title="Blog - Prithvi Rajan" description="Blog posts by Prithvi Rajan about bioinformatics, projects, research, and learning.">
  <div class="container">
    <div class="page-header">
      <p class="eyebrow">Blog</p>
      <h1>Blog <span class="accent">.</span></h1>
      <p class="page-sub">
        Posts about what I am building, learning, and thinking through in bioinformatics and research.
      </p>
    </div>

    {posts.length > 0 ? (
      <section class="post-list" aria-label="Blog posts">
        {posts.map(post => (
          <article class="post-card will-animate">
            <time datetime={post.data.date.toISOString()}>{formatDate(post.data.date)}</time>
            <h2><a href={`/blog/${post.id}`}>{post.data.title}</a></h2>
            <p>{post.data.description}</p>
          </article>
        ))}
      </section>
    ) : (
      <section class="empty-state">
        <h2>Posts coming soon.</h2>
        <p>
          This space will hold updates on projects, research, and things I am learning along the way.
        </p>
      </section>
    )}
  </div>
</Layout>

<style>
.page-header {
  padding: 3.6rem 0 2.4rem;
  border-bottom: 1px solid var(--color-border);
  margin-bottom: 2.5rem;
}
.eyebrow {
  font-family: var(--font-sans);
  font-size: 0.76rem;
  font-weight: 600;
  letter-spacing: 0.08em;
  text-transform: uppercase;
  color: var(--color-accent);
  margin-bottom: 1rem;
}
.page-header h1 { margin-bottom: 0.7rem; }
.page-sub {
  max-width: 760px;
  font-size: 1.02rem;
  color: var(--color-muted);
}
.post-list {
  display: grid;
  gap: 1rem;
  max-width: 860px;
  padding-bottom: 3.2rem;
}
.post-card,
.empty-state {
  padding: 1.25rem 1.35rem;
  border: 1px solid var(--color-border);
  border-radius: 4px;
  background: var(--color-surface);
}
.post-card time {
  display: block;
  font-family: var(--font-sans);
  font-size: 0.76rem;
  font-weight: 600;
  color: var(--color-muted);
  text-transform: uppercase;
  margin-bottom: 0.65rem;
}
.post-card h2,
.empty-state h2 {
  font-size: 1.22rem;
  line-height: 1.3;
  margin-bottom: 0.55rem;
}
.post-card h2 a:hover {
  color: var(--color-accent);
}
.post-card p,
.empty-state p {
  color: var(--color-muted);
  font-size: 0.96rem;
  line-height: 1.7;
}
.empty-state {
  max-width: 760px;
  margin-bottom: 3.2rem;
}
</style>
