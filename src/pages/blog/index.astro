---
import Layout from '../../layouts/Layout.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog'))
  .filter(post => !post.data.draft)
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());

const formatDate = (date: Date) =>
  new Intl.DateTimeFormat('en', {
    year: 'numeric',
    month: 'long',
    day: 'numeric',
  }).format(date);
---

<Layout title="Research Notes - Prithvi Rajan" description="Academic project notes by Prithvi Rajan on protein language models, molecular docking, genomics workflows, and biomedical machine learning.">
  <div class="container">
    <div class="page-header">
      <p class="eyebrow">Research notes</p>
      <h1>Research Notes <span class="accent">.</span></h1>
      <p class="page-sub">
        Short technical write-ups from selected computational biology projects. Each note is framed around
        the research question, methods, evidence, limitations, and what would make the work stronger.
      </p>
    </div>

    {posts.length > 0 ? (
      <section class="post-list" aria-label="Research notes">
        {posts.map(post => (
          <article class="post-card will-animate">
            <div class="post-meta">
              <time datetime={post.data.date.toISOString()}>{formatDate(post.data.date)}</time>
              <span>{post.data.readingTime}</span>
            </div>
            <h2><a href={`/blog/${post.id}`}>{post.data.title}</a></h2>
            <p>{post.data.description}</p>
            <div class="post-tags" aria-label="Topics">
              {post.data.tags.slice(0, 4).map(tag => <span class="tag">{tag}</span>)}
            </div>
            <div class="post-links">
              <a href={`/blog/${post.id}`}>Read note</a>
              <a href={post.data.github} target="_blank" rel="noopener">Repository</a>
            </div>
          </article>
        ))}
      </section>
    ) : (
      <section class="empty-state">
        <h2>Research notes coming soon.</h2>
        <p>
          This space will hold technical notes on methods, results, limitations, and reproducible project artifacts.
        </p>
      </section>
    )}
  </div>
</Layout>

<style>
.page-header {
  padding: 2.4rem 2rem 2rem;
  border-bottom: 1px solid var(--color-border);
  margin-bottom: 2.5rem;
}
.eyebrow {
  font-family: var(--font-sans);
  font-size: 0.76rem;
  font-weight: 600;
  letter-spacing: 0.08em;
  text-transform: uppercase;
  color: var(--color-accent);
  margin-bottom: 1rem;
}
.page-header h1 { margin-bottom: 0.7rem; }
.page-sub {
  max-width: 760px;
  font-size: 1.02rem;
  color: var(--color-muted);
}
.post-list {
  display: grid;
  gap: 1.1rem;
  max-width: 100%;
  padding-bottom: 3.2rem;
  padding-inline: 2rem;
}
.post-card,
.empty-state {
  padding: 1.25rem 1.35rem 1.2rem;
  border: 1px solid var(--color-border);
  border-radius: 4px;
  background: var(--color-surface);
}
.post-meta {
  display: flex;
  flex-wrap: wrap;
  gap: 0.45rem 0.75rem;
  font-family: var(--font-sans);
  font-size: 0.76rem;
  font-weight: 600;
  color: var(--color-muted);
  text-transform: uppercase;
  margin-bottom: 0.65rem;
}
.post-meta span::before {
  content: '/';
  color: var(--color-border);
  margin-right: 0.75rem;
}
.post-card h2,
.empty-state h2 {
  font-size: 1.22rem;
  line-height: 1.3;
  margin-bottom: 0.55rem;
}
.post-card h2 a:hover {
  color: var(--color-accent);
}
.post-card p,
.empty-state p {
  color: var(--color-muted);
  font-size: 0.96rem;
  line-height: 1.7;
}
.post-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 0.4rem 0.8rem;
  margin-top: 0.85rem;
}
.post-links {
  display: flex;
  flex-wrap: wrap;
  gap: 0.8rem;
  margin-top: 0.95rem;
}
.post-links a {
  color: var(--color-accent);
  font-size: 0.86rem;
  font-weight: 600;
  border-bottom: 1px solid currentColor;
}
.empty-state {
  max-width: 760px;
  margin-bottom: 3.2rem;
}
@media (max-width: 760px) {
  .page-header,
  .post-list { padding-inline: 0; }
}
</style>
