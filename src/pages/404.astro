---
// 404.astro
import Layout from '../layouts/Layout.astro';
---

<Layout title="404 — Page Not Found · Prithvi Rajan">
  <div class="container not-found">
    <h1>404</h1>
    <p>This page doesn't exist — maybe it moved, maybe it never did.</p>
    <a href="/" class="btn">← Back to home</a>
  </div>
</Layout>

<style>
  .not-found {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    min-height: 50vh;
    text-align: center;
    gap: 1rem;
  }
  .not-found h1 {
    font-family: var(--font-serif);
    font-size: 6rem;
    font-weight: 700;
    color: var(--color-border);
    line-height: 1;
  }
  .not-found p {
    font-size: 1rem;
    color: var(--color-muted);
    margin-bottom: 0.5rem;
  }
</style>
