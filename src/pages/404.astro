---
// 404.astro
import Layout from '../layouts/Layout.astro';
---

<Layout title="404 — Page Not Found · Prithvi Rajan">
  <div class="container not-found">
    <h1>404 <span class="accent">.</span></h1>
    <p>This page doesn't exist — maybe it moved, maybe it never did.</p>
    <a href="/" class="back-link">← Back to home</a>
  </div>
</Layout>

<style>
  .not-found {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    min-height: 55vh;
    text-align: center;
    gap: 0.8rem;
  }
  .not-found h1 {
    font-size: 5rem;
    font-weight: 700;
    line-height: 1;
  }
  .not-found p {
    font-size: 0.98rem;
    color: var(--color-muted);
    margin-bottom: 0.8rem;
  }
  .back-link {
    font-size: 0.9rem;
    font-weight: 700;
    color: var(--color-accent);
    border-bottom: 1px solid currentColor;
    line-height: 1.1;
  }
  .back-link:hover {
    color: var(--color-accent2);
  }
</style>
