---
// TimelineItem.astro — CV timeline entry
interface Props {
  period: string;
  title: string;
  institution: string;
  bullets?: string[];
  isLast?: boolean;
}

const { period, title, institution, bullets = [], isLast } = Astro.props;
---

<div class={`timeline-item will-animate ${isLast ? 'is-last' : ''}`}>
  <div class="timeline-left">
    <span class="timeline-period">{period}</span>
  </div>
  <div class="timeline-connector">
    <div class="timeline-dot"></div>
    {!isLast && <div class="timeline-line-seg"></div>}
  </div>
  <div class="timeline-right">
    <h3 class="timeline-title">{title}</h3>
    <p class="timeline-institution">{institution}</p>
    {bullets.length > 0 && (
      <ul class="timeline-bullets">
        {bullets.map(b => <li>{b}</li>)}
      </ul>
    )}
  </div>
</div>

<style>
  .timeline-item {
    display: grid;
    grid-template-columns: 130px 24px 1fr;
    gap: 0 1rem;
    padding-bottom: 2.5rem;
  }

  .timeline-item.is-last { padding-bottom: 0; }

  .timeline-left {
    padding-top: 2px;
    text-align: right;
  }

  .timeline-period {
    font-size: 0.75rem;
    font-weight: 600;
    letter-spacing: 0.03em;
    color: var(--color-muted);
    white-space: nowrap;
  }

  .timeline-connector {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0;
  }

  .timeline-dot {
    width: 10px;
    height: 10px;
    border-radius: 50%;
    background: var(--color-accent);
    border: 2px solid var(--color-bg);
    outline: 1.5px solid var(--color-border);
    flex-shrink: 0;
    margin-top: 3px;
  }

  .timeline-line-seg {
    flex: 1;
    width: 2px;
    background: var(--color-border);
    margin-top: 6px;
  }

  .timeline-right {
    padding-top: 0;
  }

  .timeline-title {
    font-family: var(--font-serif);
    font-size: 1rem;
    font-weight: 600;
    color: var(--color-text);
    margin-bottom: 0.15rem;
  }

  .timeline-institution {
    font-size: 0.83rem;
    color: var(--color-muted);
    margin-bottom: 0.65rem;
  }

  .timeline-bullets {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
  }

  .timeline-bullets li {
    font-size: 0.85rem;
    color: var(--color-muted);
    line-height: 1.55;
    padding-left: 1rem;
    position: relative;
  }

  .timeline-bullets li::before {
    content: '—';
    position: absolute;
    left: 0;
    color: var(--color-border);
  }

  @media (max-width: 580px) {
    .timeline-item {
      grid-template-columns: 1fr;
      grid-template-rows: auto;
    }
    .timeline-left { text-align: left; padding-bottom: 0.25rem; }
    .timeline-connector { display: none; }
  }
</style>
