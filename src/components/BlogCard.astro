---
interface Props {
  title: string;
  description: string;
  href: string;
  date: Date;
  tags?: string[];
  repo: string;
  github: string;
  heroImage: string;
  heroAlt: string;
  readingTime?: string;
  featured?: boolean;
}

const {
  title,
  description,
  href,
  date,
  tags = [],
  repo,
  github,
  heroImage,
  heroAlt,
  readingTime = '6 min read',
  featured = false,
} = Astro.props;

const formattedDate = date.toLocaleDateString('en', {
  year: 'numeric',
  month: 'short',
  day: 'numeric',
});
---

<article class="blog-card will-animate">
  <a href={href} class="blog-media" aria-label={`Read ${title}`}>
    <img src={heroImage} alt={heroAlt} loading="lazy" />
  </a>

  <div class="blog-body">
    <div class="blog-topline">
      <span>{formattedDate}</span>
      <span>{readingTime}</span>
      {featured && <span class="blog-badge">Featured</span>}
    </div>

    <h3 class="blog-title">
      <a href={href}>{title}</a>
    </h3>

    <p class="blog-desc">{description}</p>

    {tags.length > 0 && (
      <div class="blog-tags">
        {tags.map((tag) => <span class="tag">{tag}</span>)}
      </div>
    )}

    <div class="blog-actions">
      <a href={href} class="pub-btn">Read article</a>
      <a href={github} target="_blank" rel="noopener" class="pub-btn">Repo: {repo}</a>
    </div>
  </div>
</article>

<style>
.blog-card {
  background: var(--color-surface);
  border: 1px solid var(--color-border);
  border-radius: 16px;
  overflow: hidden;
  display: flex;
  flex-direction: column;
  min-height: 100%;
  box-shadow: var(--shadow-card);
  transition: border-color 0.25s cubic-bezier(0.4, 0, 0.2, 1), transform 0.25s cubic-bezier(0.4, 0, 0.2, 1), box-shadow 0.25s cubic-bezier(0.4, 0, 0.2, 1);
  backdrop-filter: blur(16px);
  -webkit-backdrop-filter: blur(16px);
}

.blog-card:hover {
  border-color: var(--color-accent);
  transform: translateY(-5px);
  box-shadow: var(--shadow-card-hover);
}

.blog-media {
  display: block;
  aspect-ratio: 16 / 9;
  background: var(--color-surface2);
  border-bottom: 1px solid var(--color-border);
  overflow: hidden;
}

.blog-media img {
  width: 100%;
  height: 100%;
  display: block;
  object-fit: cover;
  transition: transform 0.4s cubic-bezier(0.4, 0, 0.2, 1);
}

.blog-card:hover .blog-media img {
  transform: scale(1.03);
}

.blog-body {
  padding: 1.4rem;
  display: flex;
  flex: 1;
  flex-direction: column;
  gap: 0.9rem;
}

.blog-topline {
  display: flex;
  flex-wrap: wrap;
  gap: 0.55rem;
  align-items: center;
  font-family: var(--font-mono);
  font-size: 0.72rem;
  font-weight: 700;
  letter-spacing: 0.04em;
  text-transform: uppercase;
  color: var(--color-muted);
}

.blog-badge {
  color: var(--color-tag-text);
  background: var(--color-tag-bg);
  border: 1px solid rgba(var(--color-accent-rgb), 0.15);
  border-radius: 99px;
  padding: 0.12rem 0.5rem;
}

.blog-title {
  font-family: var(--font-heading);
  font-size: 1.12rem;
  font-weight: 800;
  line-height: 1.25;
}

.blog-title a {
  transition: color 0.15s;
}

.blog-title a:hover {
  color: var(--color-accent);
}

.blog-desc {
  font-size: 0.93rem;
  color: var(--color-muted);
  line-height: 1.55;
}

.blog-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 0.4rem;
  margin-top: auto;
  padding-top: 0.25rem;
}

.blog-actions {
  display: flex;
  flex-wrap: wrap;
  gap: 0.65rem;
  padding-top: 0.4rem;
}

.pub-btn {
  font-size: 0.78rem;
  font-weight: 700;
  color: var(--color-accent);
  border: 1px solid rgba(var(--color-accent-rgb), 0.2);
  padding: 0.4rem 0.95rem;
  border-radius: 99px;
  background: transparent;
  transition: all 0.25s cubic-bezier(0.4, 0, 0.2, 1);
  text-decoration: none;
  line-height: 1;
}

.pub-btn:hover {
  background: var(--color-tag-bg);
  border-color: var(--color-accent);
  color: var(--color-accent);
  box-shadow: 0 4px 10px rgba(var(--color-accent-rgb), 0.08);
  transform: translateY(-1px);
}
</style>
