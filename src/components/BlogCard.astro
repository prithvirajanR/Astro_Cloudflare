---
interface Props {
  title: string;
  description: string;
  href: string;
  date: Date;
  tags?: string[];
  repo: string;
  github: string;
  heroImage: string;
  heroAlt: string;
  readingTime?: string;
  featured?: boolean;
}

const {
  title,
  description,
  href,
  date,
  tags = [],
  repo,
  github,
  heroImage,
  heroAlt,
  readingTime = '6 min read',
  featured = false,
} = Astro.props;

const formattedDate = date.toLocaleDateString('en', {
  year: 'numeric',
  month: 'short',
  day: 'numeric',
});
---

<article class="blog-card will-animate">
  <a href={href} class="blog-media" aria-label={`Read ${title}`}>
    <img src={heroImage} alt={heroAlt} loading="lazy" />
  </a>

  <div class="blog-body">
    <div class="blog-topline">
      <span>{formattedDate}</span>
      <span>{readingTime}</span>
      {featured && <span class="blog-badge">Featured</span>}
    </div>

    <h3 class="blog-title">
      <a href={href}>{title}</a>
    </h3>

    <p class="blog-desc">{description}</p>

    {tags.length > 0 && (
      <div class="blog-tags">
        {tags.map((tag) => <span class="tag">{tag}</span>)}
      </div>
    )}

    <div class="blog-actions">
      <a href={href} class="pub-btn">Read article</a>
      <a href={github} target="_blank" rel="noopener" class="pub-btn">Repo: {repo}</a>
    </div>
  </div>
</article>

<style>
.blog-card {
  background: var(--color-surface);
  border: 1px solid var(--color-border);
  border-radius: 4px;
  overflow: hidden;
  display: flex;
  flex-direction: column;
  min-height: 100%;
  box-shadow: none;
  transition: border-color 0.2s ease, transform 0.2s ease;
}

.blog-card:hover {
  border-color: var(--color-accent);
  transform: translateY(-1px);
}

.blog-media {
  display: block;
  aspect-ratio: 16 / 9;
  background: var(--color-surface2);
  border-bottom: 1px solid var(--color-border);
  overflow: hidden;
}

.blog-media img {
  width: 100%;
  height: 100%;
  display: block;
  object-fit: cover;
  background: #ffffff;
}

.blog-body {
  padding: 1.05rem 1.1rem 1.15rem;
  display: flex;
  flex: 1;
  flex-direction: column;
  gap: 0.7rem;
}

.blog-topline {
  display: flex;
  flex-wrap: wrap;
  gap: 0.55rem;
  align-items: center;
  font-size: 0.72rem;
  font-weight: 700;
  letter-spacing: 0.06em;
  text-transform: uppercase;
  color: var(--color-muted);
}

.blog-badge {
  color: var(--color-accent);
  border: none;
  padding: 0;
  font-weight: 700;
}

.blog-title {
  font-family: var(--font-heading);
  font-size: 1.05rem;
  font-weight: 800;
  line-height: 1.3;
}

.blog-title a {
  transition: color 0.15s;
}

.blog-title a:hover {
  color: var(--color-accent);
}

.blog-desc {
  font-size: 0.94rem;
  color: var(--color-muted);
  line-height: 1.58;
}

.blog-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 0.4rem 0.85rem;
  margin-top: auto;
  padding-top: 0.25rem;
}

.blog-tags .tag::before {
  content: '#';
  color: var(--color-accent);
}

.blog-actions {
  display: flex;
  flex-wrap: wrap;
  gap: 0.8rem;
  margin-top: 0.25rem;
}

.pub-btn {
  font-size: 0.8rem;
  font-weight: 600;
  color: var(--color-accent);
  border: none;
  border-bottom: 1px solid currentColor;
  padding: 0;
  border-radius: 0;
  background: transparent;
  transition: background 0.15s, border-color 0.15s, color 0.15s;
  text-decoration: none;
}

.pub-btn:hover {
  background: transparent;
  color: var(--color-accent2);
  border-color: currentColor;
}
</style>
