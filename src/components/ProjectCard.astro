---
interface Props {
  title: string;
  description: string;
  tags?: string[];
  image?: string;
  imageAlt?: string;
  github?: string;
  demo?: string;
  featured?: boolean;
}
const { title, description, tags = [], image, imageAlt, github, demo, featured } = Astro.props;
---

<article class="proj-card will-animate">
  <div class="proj-media">
    {image ? (
      <img src={image} alt={imageAlt || `${title} project visual`} loading="lazy" />
    ) : (
      <div class="proj-media-fallback" aria-hidden="true">
        <div class="fallback-chart">
          <div class="chart-grid"></div>
          <span style="height: 35%"></span>
          <span style="height: 65%"></span>
          <span style="height: 50%"></span>
          <span style="height: 85%"></span>
          <span style="height: 40%"></span>
        </div>
      </div>
    )}
  </div>

  <div class="proj-body">
    <div class="proj-header">
      <h3 class="proj-title">{title}</h3>
      {featured && <span class="proj-badge">Featured</span>}
    </div>
    <p class="proj-desc">{description}</p>
    {tags.length > 0 && (
      <div class="proj-tags">
        {tags.map(t => <span class="tag">{t}</span>)}
      </div>
    )}
    {(github || demo) && (
      <div class="proj-btns">
        {github && <a href={github} target="_blank" rel="noopener" class="pub-btn">GitHub</a>}
        {demo && <a href={demo} target="_blank" rel="noopener" class="pub-btn">Live Demo</a>}
      </div>
    )}
  </div>
</article>

<style>
.proj-card {
  background: var(--color-surface);
  border: 1px solid var(--color-border);
  border-radius: 8px;
  overflow: hidden;
  display: flex;
  flex-direction: column;
  box-shadow: var(--shadow-card);
  transition: border-color 0.2s ease, box-shadow 0.2s ease;
}
.proj-card:hover {
  border-color: var(--color-accent);
  box-shadow: var(--shadow-card-hover);
}
.proj-media {
  aspect-ratio: 16 / 9;
  background: var(--color-surface2);
  border-bottom: 1px solid var(--color-border);
  overflow: hidden;
  position: relative;
}
.proj-media img {
  width: 100%;
  height: 100%;
  display: block;
  object-fit: cover;
  background: #ffffff;
}
.proj-media-fallback {
  width: 100%;
  height: 100%;
  display: flex;
  align-items: center;
  justify-content: center;
  background: var(--color-surface2);
  position: relative;
  overflow: hidden;
}
.fallback-chart {
  display: flex;
  align-items: end;
  justify-content: center;
  gap: 0.65rem;
  width: 70%;
  height: 60%;
  position: relative;
}
.chart-grid {
  position: absolute;
  inset: 0;
  background-image: 
    linear-gradient(rgba(0, 0, 0, 0.03) 1px, transparent 1px),
    linear-gradient(90deg, rgba(0, 0, 0, 0.03) 1px, transparent 1px);
  background-size: 16px 16px;
}
.fallback-chart span {
  display: block;
  width: 14px;
  border-radius: 2px 2px 0 0;
  background: var(--color-border);
  position: relative;
  z-index: 2;
}
.fallback-chart span:nth-child(2) { background: var(--color-accent); opacity: 0.8; }
.fallback-chart span:nth-child(3) { background: var(--color-muted); opacity: 0.6; }
.fallback-chart span:nth-child(4) { background: var(--color-border); }
.fallback-chart span:nth-child(5) { background: var(--color-accent); }
.fallback-chart span:nth-child(6) { background: var(--color-muted); opacity: 0.8; }

@keyframes pulseHeight {
  from { transform: scaleY(1); }
  to { transform: scaleY(0.85); }
}

.proj-body {
  padding: 1.5rem;
  display: flex;
  flex: 1;
  flex-direction: column;
  gap: 0.95rem;
}
.proj-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 0.75rem;
}
.proj-title {
  font-family: var(--font-heading);
  font-size: 1.15rem;
  font-weight: 800;
  line-height: 1.25;
  letter-spacing: -0.025em;
}
.proj-badge {
  font-family: var(--font-mono);
  font-size: 0.68rem;
  font-weight: 800;
  letter-spacing: 0.04em;
  text-transform: uppercase;
  color: var(--color-tag-text);
  background: var(--color-tag-bg);
  border: 1px solid rgba(var(--color-accent-rgb), 0.15);
  padding: 0.15rem 0.55rem;
  border-radius: 99px;
  white-space: nowrap;
}
.proj-desc {
  font-size: 0.94rem;
  color: var(--color-muted);
  line-height: 1.6;
}
.proj-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 0.45rem;
}
.proj-tags .tag::before {
  content: '#';
  color: var(--color-accent);
  margin-right: 0.1rem;
}
.proj-btns {
  display: flex;
  flex-wrap: wrap;
  gap: 0.5rem;
  margin-top: auto;
  padding-top: 0.25rem;
}
.pub-btn {
  font-size: 0.75rem;
  font-weight: 600;
  color: var(--color-accent);
  border: 1px solid var(--color-border);
  padding: 0.35rem 0.8rem;
  border-radius: 4px;
  background: var(--color-surface);
  transition: all 0.2s ease;
  text-decoration: none;
  line-height: 1;
}
.pub-btn:hover {
  border-color: var(--color-accent);
  background: var(--color-surface2);
}
</style>
