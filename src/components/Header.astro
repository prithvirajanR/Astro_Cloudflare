---
---

<header class="site-header">
  <div class="hdr-inner container">
    <div class="brand-stack">
      <a href="/" class="brand" aria-label="Home">
        <span class="brand-mark">PR</span>
        <span>Prithvi Rajan</span>
      </a>

      <nav class="desk-nav" aria-label="Main navigation">
        <a href="/" class="nav-link" data-path="/">About</a>
        <a href="/projects" class="nav-link" data-path="/projects">Projects</a>
        <a href="/publications" class="nav-link" data-path="/publications">Research</a>
        <a href="/blog" class="nav-link" data-path="/blog">Blog</a>
        <a href="/journey" class="nav-link" data-path="/journey">Résumé</a>
      </nav>
    </div>

    <div class="hdr-controls">
      <button id="dark-toggle" class="icon-btn" aria-label="Toggle light/dark mode">
        <svg id="i-sun" xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="4.5"/><line x1="12" y1="2" x2="12" y2="4"/><line x1="12" y1="20" x2="12" y2="22"/><line x1="4.93" y1="4.93" x2="6.34" y2="6.34"/><line x1="17.66" y1="17.66" x2="19.07" y2="19.07"/><line x1="2" y1="12" x2="4" y2="12"/><line x1="20" y1="12" x2="22" y2="12"/><line x1="4.93" y1="19.07" x2="6.34" y2="17.66"/><line x1="17.66" y1="6.34" x2="19.07" y2="4.93"/></svg>
        <svg id="i-moon" xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="display:none"><path d="M21 12.79A8.5 8.5 0 1 1 11.21 3 6.5 6.5 0 0 0 21 12.79z"/></svg>
      </button>

      <button id="mob-toggle" class="icon-btn mob-only" aria-label="Open menu" aria-expanded="false">
        <svg id="i-hburg" xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><line x1="3" y1="12" x2="21" y2="12"/><line x1="3" y1="6" x2="21" y2="6"/><line x1="3" y1="18" x2="21" y2="18"/></svg>
        <svg id="i-close" xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" style="display:none"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
      </button>
    </div>
  </div>
</header>

<div id="mob-menu" class="mob-menu" aria-hidden="true">
  <a href="/" class="mob-link">About</a>
  <a href="/projects" class="mob-link">Projects</a>
  <a href="/publications" class="mob-link">Research</a>
  <a href="/blog" class="mob-link">Blog</a>
  <a href="/journey" class="mob-link">Résumé</a>
</div>

<style is:global>
.hdr-inner {
  width: 100%;
  display: grid;
  grid-template-columns: minmax(0, 1fr) auto;
  align-items: center;
  justify-content: space-between;
  gap: 1.5rem;
  padding-block: 1rem;
}

.brand-stack {
  display: flex;
  align-items: center;
  gap: 2.5rem;
}
.brand {
  display: inline-flex;
  align-items: center;
  gap: 0.85rem;
  font-family: var(--font-heading);
  font-size: 1.35rem;
  font-weight: 850;
  color: var(--color-text);
  letter-spacing: -0.04em;
  white-space: nowrap;
  transition: opacity 0.2s;
}
.brand:hover { opacity: 0.8; }
.brand-mark {
  display: inline-grid;
  place-items: center;
  width: 38px;
  height: 38px;
  color: var(--color-btn-text);
  background: var(--color-accent);
  border: none;
  border-radius: 4px;
  font-size: 0.85rem;
  font-family: var(--font-mono);
  font-weight: 700;
  flex: 0 0 auto;
}

.desk-nav {
  display: flex;
  align-items: center;
  gap: 0.35rem;
}

.nav-link {
  font-family: var(--font-sans);
  font-size: 0.9rem;
  font-weight: 600;
  color: var(--color-muted);
  padding: 0.35rem 0.75rem;
  border-radius: 4px;
  transition: all 0.2s ease;
}
.nav-link:hover {
  color: var(--color-accent);
}
.nav-link[aria-current="page"] {
  color: var(--color-accent);
  font-weight: 700;
}

.hdr-controls {
  display: flex;
  align-items: center;
  gap: 0.5rem;
}

.icon-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 36px;
  height: 36px;
  border: 1px solid var(--color-border);
  border-radius: 99px;
  background: var(--color-surface);
  color: var(--color-muted);
  cursor: pointer;
  box-shadow: 0 2px 5px rgba(0,0,0,0.02);
  transition: all 0.25s cubic-bezier(0.4, 0, 0.2, 1);
}
.icon-btn:hover {
  color: var(--color-accent);
  border-color: var(--color-accent);
  background: var(--color-tag-bg);
  transform: translateY(-1px);
}
.icon-btn svg {
  transition: transform 0.4s ease;
}
.icon-btn:hover svg {
  transform: rotate(25deg);
}

.mob-only { display: none; }

.mob-menu {
  position: fixed;
  top: var(--header-height);
  left: 0;
  right: 0;
  background: rgba(var(--color-bg), 0.95);
  backdrop-filter: blur(16px);
  -webkit-backdrop-filter: blur(16px);
  border-bottom: 1px solid var(--color-border);
  padding: 0.8rem 2rem 1.6rem;
  display: none;
  flex-direction: column;
  gap: 0.2rem;
  z-index: 99;
  visibility: hidden;
  pointer-events: none;
  transform: translateY(-20px);
  opacity: 0;
  transition: all 0.3s cubic-bezier(0.16, 1, 0.3, 1);
}
.mob-menu.open {
  visibility: visible;
  pointer-events: auto;
  transform: translateY(0);
  opacity: 1;
}

.mob-link {
  font-family: var(--font-sans);
  font-size: 1.05rem;
  font-weight: 700;
  color: var(--color-text);
  padding: 0.8rem 1rem;
  border-radius: 8px;
  transition: all 0.2s;
}
.mob-link:hover,
.mob-link[aria-current="page"] {
  color: var(--color-accent);
  background: var(--color-tag-bg);
}

@media (max-width: 860px) {
  .desk-nav { display: none; }
  .mob-only { display: flex; }
  .mob-menu { display: flex; }
}

@media (max-width: 700px) {
  .hdr-inner {
    padding-block: 0.75rem;
  }
  .brand {
    font-size: 1.15rem;
  }
}
</style>

<script is:inline>
  function syncHeaderIcons() {
    var isDark = document.documentElement.classList.contains('dark');
    var sun = document.getElementById('i-sun');
    var moon = document.getElementById('i-moon');
    if (sun) sun.style.display = isDark ? 'block' : 'none';
    if (moon) moon.style.display = isDark ? 'none' : 'block';
  }

  function initHeader() {
    syncHeaderIcons();

    var themeBtn = document.getElementById('dark-toggle');
    if (themeBtn) {
      var themeFresh = themeBtn.cloneNode(true);
      themeBtn.parentNode.replaceChild(themeFresh, themeBtn);
      themeFresh.addEventListener('click', function() {
        var nowDark = document.documentElement.classList.toggle('dark');
        localStorage.setItem('theme', nowDark ? 'dark' : 'light');
        syncHeaderIcons();
      });
      syncHeaderIcons();
    }

    var path = window.location.pathname;
    document.querySelectorAll('.nav-link, .mob-link').forEach(function(link) {
      var href = link.getAttribute('href');
      var active = (href === '/' && path === '/') ||
        (href !== '/' && path.startsWith(href));
      if (active) link.setAttribute('aria-current', 'page');
      else link.removeAttribute('aria-current');
    });

    var mobBtn = document.getElementById('mob-toggle');
    var mobMenu = document.getElementById('mob-menu');
    if (mobBtn && mobMenu) {
      var mFresh = mobBtn.cloneNode(true);
      mobBtn.parentNode.replaceChild(mFresh, mobBtn);
      mFresh.addEventListener('click', function() {
        var open = mobMenu.classList.toggle('open');
        mFresh.setAttribute('aria-expanded', String(open));
        var hb = document.getElementById('i-hburg');
        var ic = document.getElementById('i-close');
        if (hb) hb.style.display = open ? 'none' : 'block';
        if (ic) ic.style.display = open ? 'block' : 'none';
      });
    }
  }

  document.addEventListener('astro:page-load', initHeader);
  initHeader();
</script>
