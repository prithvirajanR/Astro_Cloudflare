---
---

<header class="site-header">
  <div class="hdr-inner container-wide">
    <a href="/" class="brand" aria-label="Home">
      <span class="brand-mark">PR</span>
      <span>Prithvi Rajan</span>
    </a>

    <nav class="desk-nav" aria-label="Main navigation">
      <a href="/" class="nav-link" data-path="/">About</a>
      <a href="/journey" class="nav-link" data-path="/journey">Journey</a>
      <a href="/publications" class="nav-link" data-path="/publications">Research</a>
      <a href="/projects" class="nav-link" data-path="/projects">Projects</a>
      <a href="/blog" class="nav-link" data-path="/blog">Blog</a>
      <a href="/Prithivi_Rajan_CV.pdf" class="nav-link" target="_blank" rel="noopener">Résumé</a>
    </nav>

    <div class="header-actions">
      <button class="theme-dot" aria-label="Theme control" type="button">☼</button>
      <button id="mob-toggle" class="icon-btn mob-only" aria-label="Open menu" aria-expanded="false">
        <svg id="i-hburg" xmlns="http://www.w3.org/2000/svg" width="19" height="19" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><line x1="3" y1="12" x2="21" y2="12"/><line x1="3" y1="6" x2="21" y2="6"/><line x1="3" y1="18" x2="21" y2="18"/></svg>
        <svg id="i-close" xmlns="http://www.w3.org/2000/svg" width="19" height="19" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" style="display:none"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
      </button>
    </div>
  </div>
</header>

<div id="mob-menu" class="mob-menu" aria-hidden="true">
  <a href="/" class="mob-link">About</a>
  <a href="/journey" class="mob-link">Journey</a>
  <a href="/publications" class="mob-link">Research</a>
  <a href="/projects" class="mob-link">Projects</a>
  <a href="/blog" class="mob-link">Blog</a>
  <a href="/Prithivi_Rajan_CV.pdf" class="mob-link" target="_blank" rel="noopener">Résumé</a>
</div>

<style is:global>
.hdr-inner {
  width: 100%;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 1.5rem;
}

.brand {
  display: inline-flex;
  align-items: center;
  gap: 0.75rem;
  color: var(--color-text);
  font-family: var(--font-heading);
  font-size: 1.05rem;
  font-weight: 800;
  letter-spacing: -0.03em;
  white-space: nowrap;
}

.brand-mark {
  display: inline-grid;
  place-items: center;
  width: 42px;
  height: 42px;
  color: white;
  background: linear-gradient(135deg, var(--color-text), var(--color-blue));
  border-radius: 8px;
  font-size: 0.82rem;
  letter-spacing: 0;
}

.desk-nav {
  display: flex;
  align-items: center;
  gap: 0.2rem;
  padding: 0;
  background: transparent;
  border: 0;
  border-radius: 0;
}

.nav-link {
  color: var(--color-muted);
  border-radius: 7px;
  padding: 0.48rem 0.85rem;
  font-family: var(--font-heading);
  font-size: 0.84rem;
  font-weight: 700;
  transition: color 0.15s ease, background 0.15s ease;
}

.nav-link:hover,
.nav-link[aria-current="page"] {
  color: var(--color-text);
  background: transparent;
  box-shadow: inset 0 -2px 0 var(--color-accent);
}

.header-actions {
  display: flex;
  align-items: center;
  gap: 0.75rem;
}

.theme-dot,
.icon-btn {
  display: inline-grid;
  place-items: center;
  width: 40px;
  height: 40px;
  color: var(--color-text);
  background: white;
  border: 1px solid var(--color-border);
  border-radius: 8px;
  cursor: pointer;
}

.theme-dot {
  color: oklch(0.48 0.035 245);
  font-size: 1rem;
}

.mob-only { display: none; }

.mob-menu {
  position: fixed;
  top: var(--header-height);
  left: 0;
  right: 0;
  z-index: 90;
  display: flex;
  flex-direction: column;
  gap: 0.15rem;
  padding: 0.75rem 1.25rem 1.25rem;
  background: color-mix(in oklch, var(--color-bg) 94%, white);
  border-bottom: 1px solid var(--color-border);
  transform: translateY(-120%);
  transition: transform 0.22s ease;
}

.mob-menu.open { transform: translateY(0); }

.mob-link {
  color: var(--color-text);
  border-bottom: 1px solid color-mix(in oklch, var(--color-border) 60%, transparent);
  padding: 0.78rem 0;
  font-family: var(--font-heading);
  font-weight: 700;
}

.mob-link:last-child { border-bottom: none; }

@media (max-width: 720px) {
  .desk-nav { display: none; }
  .theme-dot { display: none; }
  .mob-only { display: inline-grid; }
}
</style>

<script is:inline>
  function initHeader() {
    var path = window.location.pathname;
    document.querySelectorAll('.nav-link, .mob-link').forEach(function(link) {
      var href = link.getAttribute('href');
      var active = (href === '/' && path === '/') ||
                   (href !== '/' && path.startsWith(href));
      if (active) link.setAttribute('aria-current', 'page');
      else link.removeAttribute('aria-current');
    });

    var mobBtn = document.getElementById('mob-toggle');
    var mobMenu = document.getElementById('mob-menu');
    if (mobBtn && mobMenu) {
      var fresh = mobBtn.cloneNode(true);
      mobBtn.parentNode.replaceChild(fresh, mobBtn);
      fresh.addEventListener('click', function() {
        var open = mobMenu.classList.toggle('open');
        fresh.setAttribute('aria-expanded', String(open));
        mobMenu.setAttribute('aria-hidden', String(!open));
        var hb = document.getElementById('i-hburg');
        var ic = document.getElementById('i-close');
        if (hb) hb.style.display = open ? 'none' : 'block';
        if (ic) ic.style.display = open ? 'block' : 'none';
      });
    }
  }

  document.addEventListener('astro:page-load', initHeader);
  initHeader();
</script>
