---
import Header from '../components/Header.astro';
import '../styles/global.css';
import { ClientRouter } from 'astro:transitions';

interface Props {
  title?: string;
  description?: string;
  ogImage?: string;
}

const {
  title = 'Prithvi Rajan | Data Scientist and Bioinformatician',
  description = 'Personal portfolio of Prithvi Rajan, a data analyst, Oracle DBA, and M.Sc. Bioinformatics student in Berlin.',
  ogImage = '/prof_pic.jpg',
} = Astro.props;

const canonicalURL = new URL(Astro.url.pathname, Astro.site);
---

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="description" content={description} />
  <meta name="keywords" content="Prithvi Rajan, bioinformatics, data scientist, Oracle DBA, portfolio, Berlin" />
  <meta name="author" content="Prithvi Rajan" />
  <meta property="og:title" content={title} />
  <meta property="og:description" content={description} />
  <meta property="og:image" content={ogImage} />
  <meta property="og:url" content={canonicalURL} />
  <meta property="og:type" content="website" />
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content={title} />
  <meta name="twitter:description" content={description} />
  <meta name="twitter:image" content={ogImage} />
  <link rel="canonical" href={canonicalURL} />
  <link rel="icon" href="/favicon.ico" sizes="any" />
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <title>{title}</title>
  <script is:inline>
    (function() {
      try {
        var storedTheme = localStorage.getItem('theme');
        var prefersDark = window.matchMedia('(prefers-color-scheme: dark)').matches;
        var theme = storedTheme || (prefersDark ? 'dark' : 'light');
        document.documentElement.dataset.theme = theme;
      } catch (error) {
        document.documentElement.dataset.theme = 'light';
      }
    })();
  </script>
  <ClientRouter />
</head>
<body>
  <Header />

  <main id="main-content">
    <slot />
  </main>

  <footer class="site-footer">
    <div class="container-wide footer-inner">
      <p>© {new Date().getFullYear()} Prithvi Rajan</p>
      <nav aria-label="Footer links">
        <a href="https://github.com/prithvirajanR" target="_blank" rel="noopener">GitHub</a>
        <a href="https://www.linkedin.com/in/prithvi-rajan-925879256/" target="_blank" rel="noopener">LinkedIn</a>
        <a href="mailto:prithvi.rajan300@gmail.com">Email</a>
      </nav>
    </div>
  </footer>

  <script>
    function initAnimations() {
      const obs = new IntersectionObserver((entries) => {
        entries.forEach((entry, i) => {
          if (entry.isIntersecting) {
            const el = entry.target as HTMLElement;
            el.style.animationDelay = `${i * 55}ms`;
            el.classList.add('animate-fade-up');
            el.classList.remove('will-animate');
            obs.unobserve(el);
          }
        });
      }, { threshold: 0.06, rootMargin: '0px 0px -30px 0px' });

      document.querySelectorAll('.will-animate').forEach(el => obs.observe(el));
    }

    initAnimations();
    document.addEventListener('astro:page-load', initAnimations);
  </script>
</body>
</html>

<style>
  #main-content {
    min-height: calc(100vh - var(--header-height));
    padding-bottom: 4rem;
  }

  .site-footer {
    border-top: 1px solid var(--color-border);
    padding: 1.5rem 0;
    color: var(--color-muted);
    background: color-mix(in oklch, var(--color-bg) 88%, var(--color-surface));
  }

  .footer-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    font-size: 0.9rem;
  }

  .footer-inner p {
    color: var(--color-muted);
    font-size: 0.9rem;
  }

  .footer-inner nav {
    display: flex;
    align-items: center;
    gap: 1rem;
  }

  .footer-inner a {
    color: var(--color-muted);
    font-weight: 700;
  }

  .footer-inner a:hover { color: var(--color-blue); }

  @media (max-width: 640px) {
    .footer-inner {
      align-items: flex-start;
      flex-direction: column;
    }
  }
</style>
