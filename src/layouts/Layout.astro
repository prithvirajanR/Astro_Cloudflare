---
// Layout.astro — Global shell with GoFolium dark theme + particle canvas
import Header from '../components/Header.astro';
import '../styles/global.css';
import { ClientRouter } from 'astro:transitions';

interface Props {
  title?: string;
  description?: string;
  ogImage?: string;
}
const {
  title = 'Prithvi Rajan — Data Scientist & Bioinformatician',
  description = 'Personal portfolio of Prithvi Rajan — data analyst, Oracle DBA, M.Sc. Bioinformatics student at Freie Universität Berlin.',
  ogImage = '/prof_pic.jpg',
} = Astro.props;
const canonicalURL = new URL(Astro.url.pathname, Astro.site);
---

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="description" content={description} />
  <meta name="keywords" content="Prithvi Rajan, bioinformatics, data analyst, Oracle DBA, portfolio, Berlin" />
  <meta name="author" content="Prithvi Rajan" />
  <meta property="og:title"       content={title} />
  <meta property="og:description" content={description} />
  <meta property="og:image"       content={ogImage} />
  <meta property="og:url"         content={canonicalURL} />
  <meta property="og:type"        content="website" />
  <meta name="twitter:card"        content="summary_large_image" />
  <meta name="twitter:title"       content={title} />
  <meta name="twitter:description" content={description} />
  <meta name="twitter:image"       content={ogImage} />
  <link rel="canonical" href={canonicalURL} />
  <link rel="icon" type="image/png" href="/favicon.png" />
  <title>{title}</title>

  <!-- Theme: default is DARK (GoFolium style). Light adds .light class -->
  <script is:inline>
    (function() {
      var stored = localStorage.getItem('theme');
      // Default: dark (no class). Light mode: add .light class
      if (stored === 'light') {
        document.documentElement.classList.add('light');
      }
    })();
  </script>

  <ClientRouter />
</head>
<body>
  <!-- Animated particle background (GoFolium signature) -->
  <canvas id="particles-canvas" aria-hidden="true"></canvas>

  <Header />

  <main id="main-content">
    <slot />
  </main>

  <footer class="site-footer">
    <div class="container">
      <p>
        © {new Date().getFullYear()} Prithvi Rajan ·
        <a href="https://github.com/prithvirajanR" target="_blank" rel="noopener" class="footer-link">GitHub</a> ·
        <a href="https://www.linkedin.com/in/prithvi-rajan-925879256/" target="_blank" rel="noopener" class="footer-link">LinkedIn</a> ·
        <a href="mailto:prithvi.rajan300@gmail.com" class="footer-link">Email</a>
      </p>
    </div>
  </footer>

  <!-- Preserve theme across View Transitions -->
  <script is:inline>
    document.addEventListener('astro:before-swap', function(e) {
      var isLight = document.documentElement.classList.contains('light');
      if (isLight) e.newDocument.documentElement.classList.add('light');
      else e.newDocument.documentElement.classList.remove('light');
    });
  </script>

  <!-- Scroll animations -->
  <script>
    function initAnimations() {
      const obs = new IntersectionObserver((entries) => {
        entries.forEach((entry, i) => {
          if (entry.isIntersecting) {
            const el = entry.target as HTMLElement;
            el.style.animationDelay = `${i * 60}ms`;
            el.classList.add('animate-fade-up');
            el.classList.remove('will-animate');
            obs.unobserve(el);
          }
        });
      }, { threshold: 0.06, rootMargin: '0px 0px -30px 0px' });
      document.querySelectorAll('.will-animate').forEach(el => obs.observe(el));
    }
    initAnimations();
    document.addEventListener('astro:page-load', initAnimations);
  </script>

  <!-- GoFolium particle animation -->
  <script is:inline>
    function initParticles() {
      var canvas = document.getElementById('particles-canvas');
      if (!canvas) return;
      var ctx = canvas.getContext('2d');
      var W, H, particles = [];
      var GREEN = '34,197,94';

      function resize() {
        W = canvas.width  = window.innerWidth;
        H = canvas.height = window.innerHeight;
      }
      resize();
      window.addEventListener('resize', resize);

      function Particle() {
        this.x = Math.random() * W;
        this.y = Math.random() * H;
        this.vx = (Math.random() - 0.5) * 0.4;
        this.vy = (Math.random() - 0.5) * 0.4;
        this.r = Math.random() * 2 + 1;
      }
      Particle.prototype.update = function() {
        this.x += this.vx;
        this.y += this.vy;
        if (this.x < 0 || this.x > W) this.vx *= -1;
        if (this.y < 0 || this.y > H) this.vy *= -1;
      };

      for (var i = 0; i < 80; i++) particles.push(new Particle());

      function draw() {
        ctx.clearRect(0, 0, W, H);
        particles.forEach(function(p) {
          p.update();
          ctx.beginPath();
          ctx.arc(p.x, p.y, p.r, 0, Math.PI * 2);
          ctx.fillStyle = 'rgba(' + GREEN + ',0.6)';
          ctx.fill();
        });
        // Connect nearby particles
        for (var a = 0; a < particles.length; a++) {
          for (var b = a + 1; b < particles.length; b++) {
            var dx = particles[a].x - particles[b].x;
            var dy = particles[a].y - particles[b].y;
            var dist = Math.sqrt(dx * dx + dy * dy);
            if (dist < 130) {
              ctx.beginPath();
              ctx.moveTo(particles[a].x, particles[a].y);
              ctx.lineTo(particles[b].x, particles[b].y);
              ctx.strokeStyle = 'rgba(' + GREEN + ',' + (1 - dist / 130) * 0.18 + ')';
              ctx.lineWidth = 0.8;
              ctx.stroke();
            }
          }
        }
        requestAnimationFrame(draw);
      }
      draw();
    }
    initParticles();
    document.addEventListener('astro:page-load', initParticles);
  </script>
</body>
</html>

<style>
  #main-content {
    padding-top: 0;
    padding-bottom: 4rem;
    min-height: calc(100vh - var(--header-height));
  }
  .site-footer {
    border-top: 1px solid var(--color-border);
    padding: 2rem 0;
    text-align: center;
    font-size: 0.85rem;
    color: var(--color-muted);
  }
  .footer-link { color: var(--color-muted); transition: color 0.15s; }
  .footer-link:hover { color: var(--color-accent); }
</style>
