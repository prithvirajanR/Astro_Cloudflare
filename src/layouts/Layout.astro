---
import Header from '../components/Header.astro';
import '../styles/global.css';
import { ClientRouter } from 'astro:transitions';

interface Props {
  title?: string;
  description?: string;
  ogImage?: string;
}

const {
  title = 'Prithvi Rajan | Data Scientist and Bioinformatician',
  description = 'Personal portfolio of Prithvi Rajan, a data analyst, Oracle DBA, and M.Sc. Bioinformatics student in Berlin.',
  ogImage = '/prof_pic.jpg',
} = Astro.props;

const canonicalURL = new URL(Astro.url.pathname, Astro.site);
---

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="description" content={description} />
  <meta name="keywords" content="Prithvi Rajan, bioinformatics, data scientist, Oracle DBA, portfolio, Berlin" />
  <meta name="author" content="Prithvi Rajan" />
  <meta property="og:title" content={title} />
  <meta property="og:description" content={description} />
  <meta property="og:image" content={ogImage} />
  <meta property="og:url" content={canonicalURL} />
  <meta property="og:type" content="website" />
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content={title} />
  <meta name="twitter:description" content={description} />
  <meta name="twitter:image" content={ogImage} />
  <link rel="canonical" href={canonicalURL} />
  <link rel="icon" href="/favicon.ico" sizes="any" />
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <title>{title}</title>

  <script is:inline>
    (function() {
      var stored = localStorage.getItem('theme');
      if (stored === 'dark') {
        document.documentElement.classList.add('dark');
      }
    })();
  </script>

  <ClientRouter />
</head>
<body>
  <div class="scroll-progress" aria-hidden="true"></div>
  <Header />

  <main id="main-content">
    <slot />
  </main>

  <footer class="site-footer">
    <div class="container footer-content">
      <p>&copy; {new Date().getFullYear()} Prithvi Rajan. Built in Berlin.</p>
      <nav class="footer-links" aria-label="Footer navigation">
        <a href="https://github.com/prithvirajanR" target="_blank" rel="noopener" class="footer-link">GitHub</a>
        <a href="https://www.linkedin.com/in/prithvi-rajan-925879256/" target="_blank" rel="noopener" class="footer-link">LinkedIn</a>
        <a href="mailto:prithvi.rajan300@gmail.com" class="footer-link">Email</a>
      </nav>
    </div>
  </footer>

  <script is:inline>
    document.addEventListener('astro:before-swap', function(e) {
      var isDark = document.documentElement.classList.contains('dark');
      if (isDark) e.newDocument.documentElement.classList.add('dark');
      else e.newDocument.documentElement.classList.remove('dark');
    });
  </script>

  <script>
    function initAnimations() {
      const obs = new IntersectionObserver((entries) => {
        entries.forEach((entry, i) => {
          if (entry.isIntersecting) {
            const el = entry.target as HTMLElement;
            el.style.animationDelay = `${i * 55}ms`;
            el.classList.add('animate-fade-up');
            el.classList.remove('will-animate');
            obs.unobserve(el);
          }
        });
      }, { threshold: 0.06, rootMargin: '0px 0px -30px 0px' });

      document.querySelectorAll('.will-animate').forEach(el => obs.observe(el));
    }

    initAnimations();
    document.addEventListener('astro:page-load', initAnimations);
  </script>

  <script is:inline>
    function initScrollProgress() {
      var bar = document.querySelector('.scroll-progress');
      if (!bar) return;

      function updateProgress() {
        var doc = document.documentElement;
        var scrollable = doc.scrollHeight - window.innerHeight;
        var progress = scrollable > 0 ? (window.scrollY / scrollable) : 0;
        bar.style.transform = 'scaleX(' + Math.min(1, Math.max(0, progress)) + ')';
      }

      updateProgress();
      window.removeEventListener('scroll', updateProgress);
      window.addEventListener('scroll', updateProgress, { passive: true });
      window.removeEventListener('resize', updateProgress);
      window.addEventListener('resize', updateProgress);
      document.addEventListener('astro:page-load', updateProgress, { once: true });
    }

    initScrollProgress();
    document.addEventListener('astro:page-load', initScrollProgress);
  </script>
</body>
</html>

<style>
  .scroll-progress {
    position: fixed;
    top: 0;
    left: 0;
    z-index: 300;
    width: 100%;
    height: 2px;
    background: var(--color-accent);
    transform: scaleX(0);
    transform-origin: left center;
    pointer-events: none;
    transition: transform 0.1s ease-out;
  }

  #main-content {
    padding-top: 0;
    padding-bottom: 3rem;
    min-height: calc(100vh - var(--header-height));
  }

  .site-footer {
    border-top: 1px solid var(--color-border);
    color: var(--color-muted);
    background: var(--color-surface);
    width: 100%;
    transition: background 0.25s, border-color 0.25s;
  }

  .footer-content {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1.5rem;
    padding-block: 2.2rem;
    font-size: 0.9rem;
    font-weight: 500;
  }

  .footer-content p {
    color: var(--color-muted);
  }

  .footer-links {
    display: flex;
    align-items: center;
    gap: 1.8rem;
  }

  .footer-link {
    color: var(--color-muted);
    font-weight: 600;
    transition: color 0.2s;
  }

  .footer-link:hover {
    color: var(--color-accent);
  }

  @media (max-width: 700px) {
    .footer-content {
      flex-direction: column;
      align-items: center;
      gap: 1rem;
      text-align: center;
    }
  }
</style>
