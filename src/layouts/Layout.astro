---
import Header from '../components/Header.astro';
import '../styles/global.css';
import { ClientRouter } from 'astro:transitions';

interface Props {
  title?: string;
  description?: string;
  ogImage?: string;
}

const {
  title = 'Prithvi Rajan - Bioinformatics MSc | Biomedical Data Systems',
  description = 'Portfolio of Prithvi Rajan, MSc Bioinformatics student in Berlin focused on structural bioinformatics, computational biology, and biomedical data systems.',
  ogImage = '/prof_pic.jpg',
} = Astro.props;

const canonicalURL = new URL(Astro.url.pathname, Astro.site);
---

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="description" content={description} />
  <meta name="keywords" content="Prithvi Rajan, bioinformatics, data scientist, structural bioinformatics, molecular docking, biomedical data systems, Freie Universitat Berlin" />
  <meta name="author" content="Prithvi Rajan" />
  <meta property="og:title" content={title} />
  <meta property="og:description" content={description} />
  <meta property="og:image" content={ogImage} />
  <meta property="og:url" content={canonicalURL} />
  <meta property="og:type" content="website" />
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content={title} />
  <meta name="twitter:description" content={description} />
  <meta name="twitter:image" content={ogImage} />
  <link rel="canonical" href={canonicalURL} />
  <link rel="icon" href="/favicon.ico" sizes="any" />
  <link rel="icon" type="image/png" href="/pr-logo-icon.png" />
  <title>{title}</title>

  <script is:inline>
    (function() {
      var stored = localStorage.getItem('theme');
      if (stored === 'dark') {
        document.documentElement.classList.add('dark');
      }
    })();
  </script>

  <ClientRouter />
</head>
<body>
  <div class="scroll-progress" aria-hidden="true"></div>
  <Header />

  <main id="main-content">
    <slot />
  </main>

  <footer class="site-footer">
    <div class="footer-content">
      <p>
        &copy; {new Date().getFullYear()} Prithvi Rajan
        <span aria-hidden="true">/</span>
        <a href="https://github.com/prithvirajanR" target="_blank" rel="noopener" class="footer-link">GitHub</a>
        <span aria-hidden="true">/</span>
        <a href="mailto:prithvi.rajan300@gmail.com" class="footer-link">Email</a>
      </p>
      <p class="footer-note">Bioinformatics, biomedical data systems, and computational biology.</p>
    </div>
  </footer>

  <script is:inline>
    document.addEventListener('astro:before-swap', function(e) {
      var isDark = document.documentElement.classList.contains('dark');
      if (isDark) e.newDocument.documentElement.classList.add('dark');
      else e.newDocument.documentElement.classList.remove('dark');
    });
  </script>

  <script>
    function initAnimations() {
      const obs = new IntersectionObserver((entries) => {
        entries.forEach((entry, i) => {
          if (entry.isIntersecting) {
            const el = entry.target as HTMLElement;
            el.style.animationDelay = `${i * 55}ms`;
            el.classList.add('animate-fade-up');
            el.classList.remove('will-animate');
            obs.unobserve(el);
          }
        });
      }, { threshold: 0.06, rootMargin: '0px 0px -30px 0px' });
      document.querySelectorAll('.will-animate').forEach(el => obs.observe(el));
    }
    initAnimations();
    document.addEventListener('astro:page-load', initAnimations);
  </script>

  <script is:inline>
    function initScrollProgress() {
      var bar = document.querySelector('.scroll-progress');
      if (!bar) return;

      function updateProgress() {
        var doc = document.documentElement;
        var scrollable = doc.scrollHeight - window.innerHeight;
        var progress = scrollable > 0 ? (window.scrollY / scrollable) : 0;
        bar.style.transform = 'scaleX(' + Math.min(1, Math.max(0, progress)) + ')';
      }

      updateProgress();
      window.removeEventListener('scroll', updateProgress);
      window.addEventListener('scroll', updateProgress, { passive: true });
      window.removeEventListener('resize', updateProgress);
      window.addEventListener('resize', updateProgress);
      document.addEventListener('astro:page-load', updateProgress, { once: true });
    }

    initScrollProgress();
    document.addEventListener('astro:page-load', initScrollProgress);
  </script>

  <script is:inline>
    function initVisitorMap() {
      var section = document.querySelector('[data-visitor-map-src]');
      if (!section) return;

      var src = section.getAttribute('data-visitor-map-src');
      var shell = document.getElementById('visitor-map-shell');
      if (!src || !shell) return;

      var existingWidget = shell.querySelector('#mapmyvisitors-widget');
      if (shell.getAttribute('data-loaded-src') === src && existingWidget) return;

      document.querySelectorAll('script#mapmyvisitors').forEach(function(script) {
        if (script.parentElement !== shell) script.remove();
      });
      document.querySelectorAll('#mapmyvisitors-widget').forEach(function(widget) {
        if (!shell.contains(widget)) widget.remove();
      });
      document.querySelectorAll('.jvectormap-tip').forEach(function(tip) {
        tip.remove();
      });

      shell.setAttribute('data-loaded-src', src);
      shell.innerHTML = '';

      var script = document.createElement('script');
      script.type = 'text/javascript';
      script.id = 'mapmyvisitors';
      script.src = src;
      shell.appendChild(script);
    }

    initVisitorMap();
    document.addEventListener('astro:page-load', initVisitorMap);
    document.addEventListener('astro:after-swap', initVisitorMap);
  </script>
</body>
</html>

<style>
  .scroll-progress {
    position: fixed;
    top: 0;
    left: 0;
    z-index: 300;
    width: 100%;
    height: 2px;
    background: var(--color-accent);
    transform: scaleX(0);
    transform-origin: left center;
    pointer-events: none;
  }
  #main-content {
    padding-top: 0;
    padding-bottom: 3rem;
    min-height: calc(100vh - var(--header-height));
  }
  .site-footer {
    border-top: 1px solid var(--color-border);
    color: var(--color-muted);
    background: var(--color-bg);
    width: 100%;
  }
  .footer-content {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    width: 100%;
    padding: 1.35rem 2rem;
    font-family: var(--font-heading);
    font-size: 0.86rem;
  }
  .footer-content p {
    color: var(--color-muted);
    font-size: 0.86rem;
    line-height: 1.4;
  }
  .footer-content span {
    color: var(--color-border);
    padding: 0 0.35rem;
  }
  .footer-link {
    color: var(--color-accent);
    transition: color 0.15s;
  }
  .footer-link:hover { color: var(--color-secondary); }
  @media (max-width: 700px) {
    .footer-content {
      flex-direction: column;
      align-items: flex-start;
      padding-inline: 1.2rem;
    }
  }
</style>
